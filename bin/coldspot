#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026 asuramaya and coldspot contributors
"""coldspot — one human entrypoint for the cold link (mirrors `phanspeed <verb>`).

  coldspot status [--json]              MB used, rate, stance, budget, top talkers
  coldspot top                          live per-app ↑/↓ view (refreshes; ctrl-c)
  coldspot link                         per-interface link health (signal/rate/loss)
  coldspot steer <iface|auto>           make the healthiest radio the primary route
  coldspot bond [auto|off|<ifaces>]     aggregate independent uplinks into one pipe
  coldspot aim [iface]                  live signal meter for aiming an antenna
  coldspot flows [--json]               per-destination breakdown (needs bpf core)
  coldspot history [--json]             per-connection usage (today + this month)
  coldspot report [today|week|month]    deep breakdown by connection + app (sqlite)
  coldspot ledger [--json]              what ate today's data (survives reloads)
  coldspot advise [--json]              proactive nudges (e.g. P2P seeding)
  coldspot policy                       what coldspot does on each of your networks
  coldspot here <open|cold|stabilize>   set the policy for the network you're on
  coldspot remember <ssid> <policy>     set policy for a named network (persists)
  coldspot forget <ssid>                drop a remembered policy (re-seeds on roam)
  coldspot stance <open|lean|siege|cold>  one-shot override (until next roam)
  coldspot siege                        shortcut for `stance siege`
  coldspot cold                         throttle everything except warmed tasks
  coldspot open                         panic release — lift all throttling/siege
  coldspot budget <MB|off>              session data ceiling; meter counts toward it
  coldspot limit <rate|off>             hard egress speed cap (1mbps, 500kbps, 1MB/s)
  coldspot stabilize auto|<down> [up]   smooth a weak/lossy link (ack-filter+ingress AQM)
  coldspot uncap <pid|name>             warm a task: full speed under cold/siege
  coldspot allow <pid|name>             alias of uncap (the by-pid primitive)
  coldspot run -- <cmd...>              launch a task warm (inside coldspot.slice)
  coldspot reset [session|day]          zero the accountant
  coldspot update [--check|--json]      pull newer releases (auto-checked daily)
  coldspot version | help
"""
import json
import os
import socket
import subprocess
import sys

RUN = "/run/coldspot"
SOCK = f"{RUN}/control.sock"
STATUS = f"{RUN}/status.json"
TS_DB = "/var/lib/coldspot/coldspot.db"   # the daemon's time-series (read-only)
STANCE_HELPER = "coldspot-stance"  # root helper, on PATH or next to us
STANCES = ("open", "lean", "siege", "cold")
HERE = os.path.dirname(os.path.realpath(__file__))


def _human(bps):
    b = float(bps)
    for u in ("B", "K", "M"):
        if b < 1024:
            return f"{b:.0f} {u}/s"
        b /= 1024
    return f"{b:.1f} G/s"


def _sock(obj):
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(3)
    try:
        s.connect(SOCK)
        s.sendall(json.dumps(obj).encode() + b"\n")
        return json.loads(s.recv(1 << 16).split(b"\n", 1)[0])
    finally:
        s.close()


def _status():
    try:
        with open(STATUS) as f:
            return json.load(f)
    except OSError:
        return None


def _set(**kw):
    kw["cmd"] = "set"
    try:
        r = _sock(kw)
    except OSError as e:
        sys.exit(f"cannot reach coldspotd ({e}); is the service running?")
    if not r.get("ok"):
        sys.exit(f"rejected: {r.get('error')}")
    return r


def _helper(*args):
    """Run the privileged stance/cgroup helper (via sudo if not root)."""
    bin_ = STANCE_HELPER
    local = os.path.join(HERE, STANCE_HELPER)
    if os.path.exists(local):
        bin_ = local
    cmd = ([] if os.geteuid() == 0 else ["sudo"]) + [bin_, *args]
    return subprocess.call(cmd)


def cmd_status(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    if "--json" in args:
        print(json.dumps(st, indent=2))
        return
    s, d, b = st.get("session", {}), st.get("day", {}), st.get("budget", {})
    used = b.get("used_mb", 0)
    print(f"link    : {st.get('connection') or '?'} on {st.get('iface')}  "
          f"(metered {st.get('metered')}, stance {st.get('stance')})")
    if st.get("governed"):
        print("govern  : auto-cold (metered) — warm a task with `coldspot run/uncap`, "
              "release with `coldspot open`")
    elif st.get("auto_govern") and st.get("metered"):
        print("govern  : auto-govern on (will cold this metered link)")
    r = st.get("rate_bps") or {}
    if r:
        print(f"rate    : down {_human(r.get('rx', 0))}   up {_human(r.get('tx', 0))}")
    print(f"session : {used} MB  (rx {s.get('rx_mb', 0)} / tx {s.get('tx_mb', 0)})")
    print(f"today   : {round(d.get('rx_mb', 0) + d.get('tx_mb', 0), 1)} MB")
    if b.get("limit_mb"):
        bar = {"ok": "·", "warn": "▲", "over": "⚠"}.get(b.get("state"), "")
        arm = "  [auto-siege armed]" if st.get("auto_siege") else ""
        print(f"budget  : {used}/{b['limit_mb']} MB  ({b.get('pct')}%) {bar}{arm}")
        eta = b.get("eta")
        if eta:
            import time as _t
            when = _t.strftime("%a %H:%M", _t.localtime(eta))
            tag = "already over" if b.get("state") == "over" else f"cap ~{when}"
            print(f"forecast: {tag}  (at your average pace)")
    talkers = st.get("talkers") or []
    if talkers:
        print(f"talkers : (via {st.get('source', '?')})    ↑up / ↓down")
        for t in talkers[:8]:
            up, dn = t.get("tx_mb", 0), t.get("rx_mb", 0)
            print(f"  {t['mb']:>7.1f} MB  ↑{up:>6.1f} ↓{dn:>6.1f}  {t['name']}")
    else:
        print("talkers : (none — enable systemd IPAccounting or the BPF core)")
    for a in st.get("advice") or []:
        print(f"⚠ advice : {a.get('hint')}")


def cmd_flows(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    flows = st.get("flows") or []
    if "--json" in args:
        print(json.dumps(flows, indent=2))
        return
    if not flows:
        print("no per-destination data — load the bpf core: sudo coldspot-bpf load")
        return
    print(f"{'MB':>8}  {'app':<14} destination")
    for f in flows[:20]:
        dst = f.get("host")
        if not dst:
            d = f["dst"]
            dst = f"[{d}]" if ":" in d else d  # bracket bare IPv6
        print(f"{f['mb']:>8.1f}  {f['app']:<14} {dst}:{f['port']}/{f['proto']}")


def _render_top(st):
    conn = st.get("connection") or "?"
    m = "metered" if st.get("metered") else "unmetered"
    r = st.get("rate_bps") or {}
    b = st.get("budget") or {}
    day = st.get("day") or {}
    print(f"coldspot top — {conn} ({m}, {st.get('stance')})"
          f"      ↑up / ↓down   (ctrl-c to quit)")
    line = (f"interface: ↓{_human(r.get('rx', 0))}  ↑{_human(r.get('tx', 0))}"
            f"   today {round(day.get('rx_mb', 0) + day.get('tx_mb', 0), 1)} MB")
    if b.get("limit_mb"):
        line += f"   budget {b.get('used_mb', 0)}/{b['limit_mb']} MB"
    print(line)
    for a in st.get("advice") or []:
        print(f"⚠ {a.get('hint')}")
    talkers = st.get("talkers") or []
    # sort by current upload+download rate when we have it, else by total bytes
    talkers = sorted(talkers, key=lambda t: (t.get("tx_bps", 0) + t.get("rx_bps", 0),
                                             t.get("mb", 0)), reverse=True)
    print(f"\n  {'↑rate':>9} {'↓rate':>9}   {'↑tot':>8} {'↓tot':>8}   app")
    for t in talkers[:15]:
        print(f"  {_human(t.get('tx_bps', 0)):>9} {_human(t.get('rx_bps', 0)):>9}   "
              f"{t.get('tx_mb', 0):>7.1f}M {t.get('rx_mb', 0):>7.1f}M   {t['name']}")
    if not talkers:
        print("  (no talkers — load the bpf core: sudo coldspot-bpf load)")


def cmd_top(args):
    import time
    once = "--once" in args
    try:
        while True:
            st = _status()
            sys.stdout.write("\x1b[2J\x1b[H")   # clear screen, cursor home
            if st is None:
                print("coldspotd not running (no status).")
            else:
                _render_top(st)
            sys.stdout.flush()
            if once:
                break
            time.sleep(2)
    except KeyboardInterrupt:
        pass


# ---- link health (the layer-1/2 axis) -------------------------------------
_SCORE_COL = {"good": "92", "ok": "32", "weak": "33",
              "bad": "91", "down": "90", "unknown": "90"}


def _sigbar(dbm, width=12):
    """A -92..-40 dBm bar."""
    if dbm is None:
        return "·" * width
    n = max(0, min(width, round((dbm + 92) * width / 52)))
    return "█" * n + "·" * (width - n)


def _render_link(ifc, h):
    score = h.get("score", "unknown")
    col = _SCORE_COL.get(score, "0")
    if not h.get("connected"):
        print(f"  \033[90m○ {ifc:<17} disconnected\033[0m")
        return
    ssid = (h.get("ssid") or "?")[:16]
    sig = h.get("signal_dbm")
    band, ch = h.get("band") or "?", h.get("channel")
    rx, tx = h.get("rx_mbps"), h.get("tx_mbps")
    tp, tf = h.get("tx_packets") or 0, h.get("tx_failed") or 0
    loss = f"{100 * tf / tp:.1f}%" if tp else "—"
    ps = "  \033[33m⚡psave\033[0m" if h.get("power_save") else ""
    active = "  \033[1m← active\033[0m" if h.get("active") else ""
    sigtxt = f"{sig} dBm" if sig is not None else "? dBm"
    print(f"  \033[{col}m● {ifc:<17}\033[0m {ssid:<16} "
          f"\033[{col}m{score:<4} {sigtxt:>8} {_sigbar(sig)}\033[0m  "
          f"{band}/ch{ch}  ↓{rx or '?'}/↑{tx or '?'}M  loss {loss}{ps}{active}")


def cmd_link(args):
    """Per-interface link health: signal, band/channel, PHY rate, loss, score.
    The 'how good is the link' view — the sibling of `top` ('who's using it')."""
    st = _status()
    links = (st or {}).get("links") or {}
    if not links:
        sys.exit("no link data yet (is coldspotd running? the sensor needs `iw`)")
    print("  \033[1mlink health\033[0m")
    order = sorted(links.items(), key=lambda kv: (not kv[1].get("active"), kv[0]))
    for ifc, h in order:
        _render_link(ifc, h)
    primary, best = st.get("primary"), st.get("best_link")
    if best and primary and best != primary:
        print(f"  \033[33m→ {best} looks healthier than the active {primary}; "
              f"`coldspot steer {best}` to switch\033[0m")


def _sig_col(dbm):
    if dbm is None:
        return "90"
    if dbm >= -65:
        return "92"
    if dbm >= -72:
        return "32"
    if dbm >= -80:
        return "33"
    if dbm >= -86:
        return "91"
    return "31"


def cmd_aim(args):
    """Live signal meter for antenna positioning. Reads the associated link's
    dBm + PHY rate ~2×/sec — move the antenna, watch 'best' climb, tape it down.
    (Aiming at an AP you're not associated to needs a root scan: ~/cs-aim.sh.)"""
    import time
    import re
    import subprocess
    iface = next((a for a in args if not a.startswith("-")), None)
    if not iface:
        links = (_status() or {}).get("links") or {}
        iface = next((i for i, h in links.items() if h.get("active")), None) \
            or _default_iface()
    if not iface:
        sys.exit("usage: coldspot aim <iface>")
    best = None
    try:
        while True:
            out = subprocess.run(["iw", "dev", iface, "link"],
                                 capture_output=True, text=True).stdout
            sys.stdout.write("\x1b[2J\x1b[H")
            if "Connected to" not in out:
                print(f"  \033[1maim\033[0m  {iface}: not associated.")
                print("  aim at an AP you're not on yet:  sudo bash ~/cs-aim.sh")
            else:
                def g(p, c=str):
                    mm = re.search(p, out)
                    return c(mm.group(1)) if mm else None
                sig = g(r"signal:\s*(-?\d+)", int)
                ssid = g(r"SSID:\s*(.+)") or "?"
                rx, tx = g(r"rx bitrate:\s*([\d.]+)"), g(r"tx bitrate:\s*([\d.]+)")
                if sig is not None and (best is None or sig > best):
                    best = sig
                col = _sig_col(sig)
                print(f"  \033[1maim\033[0m  {iface}  →  {ssid}\n")
                st = f"{sig} dBm" if sig is not None else "? dBm"
                print(f"  now   \033[{col}m{st:>8}  {_sigbar(sig)}\033[0m")
                if best is not None:
                    print(f"  best  \033[1m{best:>4} dBm\033[0m   "
                          f"← beat it, then tape it down")
                print(f"  rate  ↓{rx or '?'}/↑{tx or '?'} Mbit   "
                      f"← climbs as the signal improves")
            print("\n  Ctrl-C to stop")
            sys.stdout.flush()
            time.sleep(0.5)
    except KeyboardInterrupt:
        pass


def _report_window(period):
    """(sql_condition, params, label) selecting an hour-range from app_usage."""
    import time
    if period == "today":
        d = time.strftime("%Y-%m-%d")
        return "substr(hour,1,10) = ?", (d,), f"today ({d})"
    if period == "week":
        wk = time.strftime("%Y-%m-%d", time.localtime(time.time() - 6 * 86400))
        return "substr(hour,1,10) >= ?", (wk,), f"last 7 days (since {wk})"
    ym = time.strftime("%Y-%m")
    return "substr(hour,1,7) = ?", (ym,), f"this month ({ym})"


def cmd_report(args):
    import sqlite3
    period = next((a for a in args if a in ("today", "week", "month")), "month")
    cond, params, label = _report_window(period)
    try:
        db = sqlite3.connect(f"file:{TS_DB}?mode=ro", uri=True)
    except sqlite3.OperationalError:
        sys.exit("no time-series yet — needs the bpf core and a running daemon.")
    try:
        by_conn = db.execute(
            f"SELECT connection, SUM(rx), SUM(tx), MAX(metered) FROM app_usage "
            f"WHERE {cond} GROUP BY connection "
            f"ORDER BY SUM(rx)+SUM(tx) DESC", params).fetchall()
        by_app = db.execute(
            f"SELECT app, SUM(rx), SUM(tx) FROM app_usage WHERE {cond} "
            f"GROUP BY app ORDER BY SUM(rx)+SUM(tx) DESC LIMIT 15", params).fetchall()
    except sqlite3.OperationalError:
        sys.exit("no time-series yet — needs the bpf core and a running daemon.")
    by_link = []
    try:   # link_health is newer; tolerate a DB that predates it
        by_link = db.execute(
            f"SELECT iface, connection, SUM(samples), SUM(sig_samples), "
            f"SUM(sig_sum), MIN(sig_min), MAX(sig_max), SUM(fades) "
            f"FROM link_health WHERE {cond} GROUP BY iface, connection "
            f"ORDER BY SUM(samples) DESC", params).fetchall()
    except sqlite3.OperationalError:
        pass
    finally:
        db.close()

    def _linkstat(r):
        ifc, conn, samp, ssamp, ssum, smin, smax, fades = r
        avg = round(ssum / ssamp) if ssamp else None
        fpct = round(100 * (fades or 0) / samp, 1) if samp else 0.0
        return ifc, conn, avg, smin, smax, fades, fpct
    if "--json" in args:
        print(json.dumps({"period": period,
                          "connections": [{"connection": c, "metered": bool(m),
                                           "rx_mb": round(rx / 1e6, 1),
                                           "tx_mb": round(tx / 1e6, 1)}
                                          for c, rx, tx, m in by_conn],
                          "apps": [{"app": a, "rx_mb": round(rx / 1e6, 1),
                                    "tx_mb": round(tx / 1e6, 1)}
                                   for a, rx, tx in by_app],
                          "links": [{"iface": i, "connection": c,
                                     "avg_dbm": avg, "min_dbm": lo, "max_dbm": hi,
                                     "fades": f, "fade_pct": fp}
                                    for i, c, avg, lo, hi, f, fp
                                    in map(_linkstat, by_link)]}, indent=2))
        return
    if not by_conn:
        print(f"report — {label}: no data yet.")
        return
    print(f"report — {label}    ↑up / ↓down")
    print("by connection:")
    for c, rx, tx, m in by_conn:
        flag = "M" if m else " "
        print(f"  {(rx + tx) / 1e6:>9.1f} MB  ↑{tx / 1e6:>8.1f} ↓{rx / 1e6:>8.1f}"
              f"  {flag} {c}")
    print("by app:")
    for a, rx, tx in by_app:
        print(f"  {(rx + tx) / 1e6:>9.1f} MB  ↑{tx / 1e6:>8.1f} ↓{rx / 1e6:>8.1f}"
              f"  {a}")
    if by_link:
        print("link health (avg/min signal, fades = how often it dropped):")
        for i, c, avg, lo, hi, f, fp in map(_linkstat, by_link):
            av = f"{avg} dBm" if avg is not None else "  ?  "
            rng = f"(min {lo})" if lo is not None else ""
            print(f"  {av:>8} {rng:<10} fades {f or 0:>4} ({fp:>4.1f}%)  "
                  f"{i}  {c}")


def cmd_history(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    hist = st.get("history") or {}
    if "--json" in args:
        print(json.dumps(hist, indent=2))
        return
    if not hist:
        print("no per-connection history yet.")
        return
    # busiest this month first; a 'M' marks the metered links (the ones that cost)
    rows = sorted(hist.items(), key=lambda kv: kv[1].get("month_mb", 0), reverse=True)
    print(f"{'today':>9} ({'↑':>6}/{'↓':>6})  {'month':>9}   connection")
    for name, rec in rows:
        flag = "M" if rec.get("metered") else " "
        print(f"{rec.get('today_mb', 0):>8.1f} ({rec.get('today_tx_mb', 0):>6.1f}/"
              f"{rec.get('today_rx_mb', 0):>6.1f})  {rec.get('month_mb', 0):>8.1f}  "
              f"{flag} {name}")


def cmd_ledger(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    led = st.get("ledger") or []
    if "--json" in args:
        print(json.dumps(led, indent=2))
        return
    if not led:
        print("no ledger yet — needs the bpf core (sudo coldspot-bpf load).")
        return
    print("today — what ate your data:    ↑up / ↓down")
    for e in led:
        up, dn = e.get("tx_mb", 0), e.get("rx_mb", 0)
        print(f"  {e['mb']:>8.1f} MB  ↑{up:>7.1f} ↓{dn:>7.1f}  {e['name']}")


def cmd_advise(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    adv = st.get("advice") or []
    if "--json" in args:
        print(json.dumps(adv, indent=2))
        return
    if not adv:
        print("nothing to flag — no heavy uploads or seeding right now.")
        return
    for a in adv:
        print(f"⚠ {a.get('hint')}")


def cmd_stance(args):
    if not args or args[0] not in STANCES:
        sys.exit(f"usage: coldspot stance <{'|'.join(STANCES)}>")
    name = args[0]
    _helper("stance", name)    # enforcement first — never depends on the daemon
    try:                       # then update the meter (best-effort)
        _sock({"cmd": "set", "stance": name})
    except OSError:
        pass
    print(f"stance -> {name}")


def _parse_rate(s):
    """Human rate -> bits/sec for tc. Standard units: lowercase b = bits,
    uppercase B = bytes. So 1mbps = 1 Mbit/s, 1MB/s = 8 Mbit/s. Bare number =
    bits/s."""
    import re
    is_bytes = "B" in s.split("/")[0]   # an explicit uppercase B means bytes
    m = re.match(r"\s*(\d+(?:\.\d+)?)\s*([kmg]?)", s.lower())
    if not m:
        return None
    val = float(m.group(1))
    mult = {"": 1, "k": 1e3, "m": 1e6, "g": 1e9}[m.group(2)]
    return int(val * mult * (8 if is_bytes else 1))


def _default_iface():
    try:
        with open("/proc/net/route") as f:
            for ln in f.readlines()[1:]:
                p = ln.split()
                if len(p) > 1 and p[1] == "00000000":   # default route
                    return p[0]
    except OSError:
        pass
    return None


def cmd_limit(args):
    """Set a smooth system-wide egress cap (HTB). Warmed tasks ride the priority
    class; everything else shares the leftover trickle."""
    if not args:
        sys.exit("usage: coldspot limit <rate|off>   e.g. 1mbps, 500kbps, 1MB/s")
    iface = (_status() or {}).get("iface") or _default_iface()
    if not iface:
        sys.exit("can't determine the interface (is coldspotd running?)")
    if args[0] in ("off", "0", "none"):
        sys.exit(_helper("unlimit", iface))
    bits = _parse_rate(args[0])
    if not bits or bits <= 0:
        sys.exit(f"bad rate '{args[0]}' (try 1mbps, 500kbps, 1MB/s)")
    rc = _helper("limit", iface, str(bits))
    if rc == 0:
        print(f"limit -> {args[0]} on {iface}  (~{bits // 1000} kbit/s total egress)")
    sys.exit(rc)


def _active_wifi():
    """The wifi iface carrying the default route (from the link sensor)."""
    links = (_status() or {}).get("links") or {}
    return next((i for i, h in links.items() if h.get("active")), None)


def _stabilize_auto(rest):
    """`stabilize auto [iface]` — derive the cap from the link's live PHY rate
    so we sit just under the *real* ceiling instead of crippling a good link.
    Single-stream TCP throughput runs ~half of PHY, so cap at PHY×0.5."""
    iface = (rest[0] if rest else None) or _active_wifi() \
        or (_status() or {}).get("iface") or _default_iface()
    if not iface:
        sys.exit("can't determine the interface")
    h = ((_status() or {}).get("links") or {}).get(iface, {})
    rxp, txp = h.get("rx_mbps"), h.get("tx_mbps")
    if not rxp and not txp:
        sys.exit(f"no PHY rate for {iface} yet — pass explicit rates: "
                 f"coldspot stabilize 2mbps 1mbps {iface}")
    dl_c = int((rxp or txp) * 1e6 * 0.5)
    ul_c = int((txp or rxp) * 1e6 * 0.5)
    rc = _helper("stabilize", iface, str(ul_c), str(dl_c))
    if rc == 0:
        print(f"stabilize auto -> {iface}: down≤{dl_c // 1000} up≤{ul_c // 1000} "
              f"kbit/s  (from {rxp or '?'}/{txp or '?'} Mbit PHY; "
              f"ack-filter + ingress AQM, power-save off)")
    sys.exit(rc)


def cmd_stabilize(args):
    """Weak/lossy-link tuning: cap just under the real ceiling, thin ACKs, and
    shape the download (IFB) so a bad link stops collapsing into multi-second
    latency under load. `stabilize off` clears it. Unlike `cold`, this protects
    latency on a *bad* link, not a data budget.

        coldspot stabilize auto [iface]          cap from the link's live PHY rate
        coldspot stabilize <down> [up] [iface]   e.g. 2mbps 800kbps
        coldspot stabilize off [iface]"""
    if args and args[0] == "auto":
        return _stabilize_auto(args[1:])
    off = bool(args) and args[0] in ("off", "0", "none")
    rest = args[1:] if off else list(args)
    dl = ul = None
    if not off:
        if not rest:
            sys.exit("usage: coldspot stabilize <down> [up] [iface]  e.g. 2mbps 800kbps\n"
                     "       coldspot stabilize off [iface]")
        dl = _parse_rate(rest[0])
        rest = rest[1:]
        if rest and _parse_rate(rest[0]):
            ul = _parse_rate(rest[0])
            rest = rest[1:]
        ul = ul or dl
    iface = (rest[0] if rest else None) or _active_wifi() \
        or (_status() or {}).get("iface") or _default_iface()
    if not iface:
        sys.exit("can't determine the interface (pass it: coldspot stabilize 2mbps <iface>)")
    if off:
        rc = _helper("unstabilize", iface)
        if rc == 0:
            print(f"stabilize off — {iface} back to normal")
        sys.exit(rc)
    if not dl or dl <= 0:
        sys.exit("bad rate; try: coldspot stabilize 2mbps 800kbps [iface]")
    # cap ~15% under the measured ceiling so the queue lives in our shaper (where
    # ack-filter + AQM run), not the driver's dumb FIFO where bufferbloat forms.
    ul_c, dl_c = int(ul * 0.85), int(dl * 0.85)
    rc = _helper("stabilize", iface, str(ul_c), str(dl_c))
    if rc == 0:
        print(f"stabilize -> {iface}: down≤{dl_c // 1000} up≤{ul_c // 1000} kbit/s "
              f"(ack-filter + ingress AQM + warmed-task priority, power-save off)")
    sys.exit(rc)


def _policy_cmd(obj):
    try:
        r = _sock(obj)
    except OSError as e:
        sys.exit(f"cannot reach coldspotd ({e}); is the service running?")
    if not r.get("ok"):
        sys.exit(r.get("err", "command failed"))
    return r


def cmd_here(args):
    """Set coldspot's remembered policy for the network you're on right now."""
    if not args or args[0] not in ("open", "cold", "stabilize"):
        sys.exit("usage: coldspot here <open|cold|stabilize>")
    _policy_cmd({"cmd": "policy", "here": True, "policy": args[0]})
    net = (_status() or {}).get("network", "this network")
    print(f"remembered: {net} → {args[0]}")


def cmd_remember(args):
    """Set policy for a named network (SSID): coldspot remember <ssid> <policy>."""
    if len(args) < 2 or args[-1] not in ("open", "cold", "stabilize"):
        sys.exit("usage: coldspot remember <ssid> <open|cold|stabilize>")
    net, pol = " ".join(args[:-1]), args[-1]
    _policy_cmd({"cmd": "policy", "net": net, "policy": pol})
    print(f"remembered: {net} → {pol}")


def cmd_forget(args):
    if not args:
        sys.exit("usage: coldspot forget <ssid>")
    net = " ".join(args)
    _policy_cmd({"cmd": "forget", "net": net})
    print(f"forgot: {net}  (will re-seed next time you're on it)")


def cmd_policy(args):
    """Show coldspot's memory of your networks — what it does on each."""
    st = _status() or {}
    pols = st.get("policies") or {}
    cur = st.get("network")
    if "--json" in args:
        print(json.dumps(pols, indent=2))
        return
    if not pols:
        print("no network policies yet — coldspot learns them as you roam.")
        return
    print(f"  {'network':<22} {'policy':<11} source")
    for net, rec in sorted(pols.items()):
        here = " \033[1m← here\033[0m" if net == cur else ""
        print(f"  {net:<22} {rec.get('policy', ''):<11} "
              f"{rec.get('source', '')}{here}")


def cmd_steer(args):
    """Make a link the primary route. `steer auto` picks the healthiest link
    (coldspot's ranking); `steer <iface>` forces one. The others become
    higher-metric backups, so if the primary drops, traffic fails over."""
    if not args:
        sys.exit("usage: coldspot steer <iface|auto>")
    st = _status() or {}
    if args[0] == "auto":
        iface = st.get("best_link")
        if not iface:
            sys.exit("no healthy link to steer to (is coldspotd running?)")
    else:
        iface = args[0]
    rc = _helper("steer", iface)
    if rc == 0:
        print(f"steer → {iface} is now primary; others demoted to backups")
    sys.exit(rc)


def cmd_bond(args):
    """Aggregate independent uplinks into one pipe (weighted ECMP). `bond auto`
    bonds whatever is currently healthy + independent; `bond <if> <if>...` forces
    a set; `bond off` restores single-link routing; no arg shows the state.
    Only bonds links with distinct public egress (real separate backhauls) — two
    radios on one AP, or a weak radio, are correctly left out."""
    st = _status() or {}
    if not args:
        bonded = st.get("bonded") or []
        able = st.get("bondable") or []
        print(f"  bonded now : {', '.join(bonded) if bonded else '(none)'}")
        print(f"  bondable   : {', '.join(f'{i} w{w}' for i, w in able) or '(need 2+ healthy, independent links)'}")
        for i, h in (st.get("links") or {}).items():
            if h.get("connected"):
                print(f"    {i}: {h.get('score')}  egress {h.get('egress_ip') or '?'}")
        return
    if args[0] == "off":
        sys.exit(_helper("unbond"))
    if args[0] == "auto":
        able = st.get("bondable") or []
        if len(able) < 2:
            sys.exit("nothing to bond — need 2+ healthy links with distinct egress "
                     "(check `coldspot bond`)")
        specs = [f"{i}:{w}" for i, w in able]
    else:
        specs = [a if ":" in a else f"{a}:1" for a in args]
        if len(specs) < 2:
            sys.exit("usage: coldspot bond <iface> <iface> [...] | auto | off")
    rc = _helper("bond", *specs)
    if rc == 0:
        print(f"bond → aggregated {', '.join(specs)}")
    sys.exit(rc)


def cmd_budget(args):
    if not args:
        sys.exit("usage: coldspot budget <MB|off>")
    if args[0] == "off":
        _set(budget=None)
        print("budget -> off")
        return
    try:
        mb = int(args[0])
    except ValueError:
        sys.exit("budget must be an integer number of MB, or 'off'")
    _set(budget=mb)
    print(f"budget -> {mb} MB")


def _pids_for(target):
    """[pids] for a pid, or for a process by exact name (the comm that talkers /
    `coldspot top` show). Exact-only on purpose: a fuzzy command-line match would
    catch unrelated processes that merely mention the name (including this CLI)."""
    if target.isdigit():
        return [target]
    out = subprocess.run(["pgrep", "-x", target], capture_output=True, text=True).stdout
    return out.split()


def cmd_uncap(args):
    """Warm a task so it keeps full speed under cold (and survives siege). By pid
    or process name; the task moves into coldspot.slice, the warmed subtree."""
    if not args:
        sys.exit("usage: coldspot uncap <pid|name>")
    target = args[0]
    pids = _pids_for(target)
    if not pids:
        sys.exit(f"no process matching '{target}'")
    rc = 0
    for p in pids:
        rc |= _helper("allow", p)
    print(f"warmed {target} ({len(pids)} pid(s)) — full speed even under cold")
    sys.exit(rc)


def cmd_allow(args):
    if not args:
        sys.exit("usage: coldspot allow <pid|name>")
    # allow is the by-pid primitive; uncap adds name resolution on top
    if not args[0].isdigit():
        return cmd_uncap(args)
    sys.exit(_helper("allow", args[0]))


def cmd_run(args):
    if not args:
        sys.exit("usage: coldspot run -- <cmd...>")
    if args and args[0] == "--":
        args = args[1:]
    sys.exit(_helper("run", *args))


def cmd_reset(args):
    scope = args[0] if args else "session"
    try:
        _sock({"cmd": "reset", "scope": scope})
    except OSError as e:
        sys.exit(f"cannot reach coldspotd ({e})")
    print(f"reset -> {scope}")


def cmd_update(args):
    """Delegate to coldspot-update (next to us or on PATH). --check/--json pass
    through; a bare `update` installs in place via sudo when newer."""
    check = "--check" in args or "--json" in args
    for u in (os.path.join(HERE, "coldspot-update"), "coldspot-update"):
        try:
            # the installer re-execs with sudo itself; --check/--json never need root
            cmd = ([] if (check or os.geteuid() == 0) else ["sudo"]) + [u, *args]
            sys.exit(subprocess.call(cmd))
        except FileNotFoundError:
            continue
    sys.exit("coldspot-update not found; reinstall coldspot.")


def cmd_version(args):
    for p in (os.path.join(HERE, "..", "share", "coldspot", "VERSION"),
              "/usr/local/share/coldspot/VERSION",
              "/usr/share/coldspot/VERSION",
              os.path.join(HERE, "..", "VERSION")):
        try:
            print("coldspot", open(p).read().strip())
            return
        except OSError:
            continue
    print("coldspot (unknown version)")


def main():
    argv = sys.argv[1:]
    if not argv or argv[0] in ("help", "-h", "--help"):
        print(__doc__.strip())
        return
    verb, rest = argv[0], argv[1:]
    table = {
        "status": cmd_status, "flows": cmd_flows, "stance": cmd_stance,
        "top": cmd_top, "link": cmd_link, "aim": cmd_aim,
        "history": cmd_history, "ledger": cmd_ledger, "advise": cmd_advise,
        "report": cmd_report,
        "budget": cmd_budget, "allow": cmd_allow, "uncap": cmd_uncap,
        "limit": cmd_limit, "stabilize": cmd_stabilize, "run": cmd_run,
        "policy": cmd_policy, "here": cmd_here, "remember": cmd_remember,
        "forget": cmd_forget, "steer": cmd_steer, "bond": cmd_bond,
        "reset": cmd_reset, "version": cmd_version,
        "update": cmd_update, "check-update": lambda a: cmd_update(["--check", *a]),
        "siege": lambda a: cmd_stance(["siege"]),
        "cold": lambda a: cmd_stance(["cold"]),
        "open": lambda a: cmd_stance(["open"]),   # panic release
    }
    fn = table.get(verb)
    if not fn:
        sys.exit(f"unknown verb '{verb}' (try: coldspot help)")
    fn(rest)


if __name__ == "__main__":
    main()
