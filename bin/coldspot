#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026 asuramaya and coldspot contributors
"""coldspot — one human entrypoint for the cold link (mirrors `phanspeed <verb>`).

  coldspot status [--json]              MB used, rate, stance, budget, top talkers
  coldspot top                          live per-app ↑/↓ view (refreshes; ctrl-c)
  coldspot flows [--json]               per-destination breakdown (needs bpf core)
  coldspot history [--json]             per-connection usage (today + this month)
  coldspot report [today|week|month]    deep breakdown by connection + app (sqlite)
  coldspot ledger [--json]              what ate today's data (survives reloads)
  coldspot advise [--json]              proactive nudges (e.g. P2P seeding)
  coldspot stance <open|lean|siege|cold>  the stances; open = no-op
  coldspot siege                        shortcut for `stance siege`
  coldspot cold                         throttle everything except warmed tasks
  coldspot open                         panic release — lift all throttling/siege
  coldspot budget <MB|off>              session data ceiling; meter counts toward it
  coldspot allow <pid|name>             whitelist a task for siege (delegates to helper)
  coldspot run -- <cmd...>              launch a task inside the coldspot cgroup
  coldspot reset [session|day]          zero the accountant
  coldspot update [--check|--json]      pull newer releases (auto-checked daily)
  coldspot version | help
"""
import json
import os
import socket
import subprocess
import sys

RUN = "/run/coldspot"
SOCK = f"{RUN}/control.sock"
STATUS = f"{RUN}/status.json"
TS_DB = "/var/lib/coldspot/coldspot.db"   # the daemon's time-series (read-only)
STANCE_HELPER = "coldspot-stance"  # root helper, on PATH or next to us
STANCES = ("open", "lean", "siege", "cold")
HERE = os.path.dirname(os.path.realpath(__file__))


def _human(bps):
    b = float(bps)
    for u in ("B", "K", "M"):
        if b < 1024:
            return f"{b:.0f} {u}/s"
        b /= 1024
    return f"{b:.1f} G/s"


def _sock(obj):
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(3)
    try:
        s.connect(SOCK)
        s.sendall(json.dumps(obj).encode() + b"\n")
        return json.loads(s.recv(1 << 16).split(b"\n", 1)[0])
    finally:
        s.close()


def _status():
    try:
        with open(STATUS) as f:
            return json.load(f)
    except OSError:
        return None


def _set(**kw):
    kw["cmd"] = "set"
    try:
        r = _sock(kw)
    except OSError as e:
        sys.exit(f"cannot reach coldspotd ({e}); is the service running?")
    if not r.get("ok"):
        sys.exit(f"rejected: {r.get('error')}")
    return r


def _helper(*args):
    """Run the privileged stance/cgroup helper (via sudo if not root)."""
    bin_ = STANCE_HELPER
    local = os.path.join(HERE, STANCE_HELPER)
    if os.path.exists(local):
        bin_ = local
    cmd = ([] if os.geteuid() == 0 else ["sudo"]) + [bin_, *args]
    return subprocess.call(cmd)


def cmd_status(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    if "--json" in args:
        print(json.dumps(st, indent=2))
        return
    s, d, b = st.get("session", {}), st.get("day", {}), st.get("budget", {})
    used = b.get("used_mb", 0)
    print(f"link    : {st.get('connection') or '?'} on {st.get('iface')}  "
          f"(metered {st.get('metered')}, stance {st.get('stance')})")
    r = st.get("rate_bps") or {}
    if r:
        print(f"rate    : down {_human(r.get('rx', 0))}   up {_human(r.get('tx', 0))}")
    print(f"session : {used} MB  (rx {s.get('rx_mb', 0)} / tx {s.get('tx_mb', 0)})")
    print(f"today   : {round(d.get('rx_mb', 0) + d.get('tx_mb', 0), 1)} MB")
    if b.get("limit_mb"):
        bar = {"ok": "·", "warn": "▲", "over": "⚠"}.get(b.get("state"), "")
        arm = "  [auto-siege armed]" if st.get("auto_siege") else ""
        print(f"budget  : {used}/{b['limit_mb']} MB  ({b.get('pct')}%) {bar}{arm}")
        eta = b.get("eta")
        if eta:
            import time as _t
            when = _t.strftime("%a %H:%M", _t.localtime(eta))
            tag = "already over" if b.get("state") == "over" else f"cap ~{when}"
            print(f"forecast: {tag}  (at your average pace)")
    talkers = st.get("talkers") or []
    if talkers:
        print(f"talkers : (via {st.get('source', '?')})    ↑up / ↓down")
        for t in talkers[:8]:
            up, dn = t.get("tx_mb", 0), t.get("rx_mb", 0)
            print(f"  {t['mb']:>7.1f} MB  ↑{up:>6.1f} ↓{dn:>6.1f}  {t['name']}")
    else:
        print("talkers : (none — enable systemd IPAccounting or the BPF core)")
    for a in st.get("advice") or []:
        print(f"⚠ advice : {a.get('hint')}")


def cmd_flows(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    flows = st.get("flows") or []
    if "--json" in args:
        print(json.dumps(flows, indent=2))
        return
    if not flows:
        print("no per-destination data — load the bpf core: sudo coldspot-bpf load")
        return
    print(f"{'MB':>8}  {'app':<14} destination")
    for f in flows[:20]:
        dst = f.get("host")
        if not dst:
            d = f["dst"]
            dst = f"[{d}]" if ":" in d else d  # bracket bare IPv6
        print(f"{f['mb']:>8.1f}  {f['app']:<14} {dst}:{f['port']}/{f['proto']}")


def _render_top(st):
    conn = st.get("connection") or "?"
    m = "metered" if st.get("metered") else "unmetered"
    r = st.get("rate_bps") or {}
    b = st.get("budget") or {}
    day = st.get("day") or {}
    print(f"coldspot top — {conn} ({m}, {st.get('stance')})"
          f"      ↑up / ↓down   (ctrl-c to quit)")
    line = (f"interface: ↓{_human(r.get('rx', 0))}  ↑{_human(r.get('tx', 0))}"
            f"   today {round(day.get('rx_mb', 0) + day.get('tx_mb', 0), 1)} MB")
    if b.get("limit_mb"):
        line += f"   budget {b.get('used_mb', 0)}/{b['limit_mb']} MB"
    print(line)
    for a in st.get("advice") or []:
        print(f"⚠ {a.get('hint')}")
    talkers = st.get("talkers") or []
    # sort by current upload+download rate when we have it, else by total bytes
    talkers = sorted(talkers, key=lambda t: (t.get("tx_bps", 0) + t.get("rx_bps", 0),
                                             t.get("mb", 0)), reverse=True)
    print(f"\n  {'↑rate':>9} {'↓rate':>9}   {'↑tot':>8} {'↓tot':>8}   app")
    for t in talkers[:15]:
        print(f"  {_human(t.get('tx_bps', 0)):>9} {_human(t.get('rx_bps', 0)):>9}   "
              f"{t.get('tx_mb', 0):>7.1f}M {t.get('rx_mb', 0):>7.1f}M   {t['name']}")
    if not talkers:
        print("  (no talkers — load the bpf core: sudo coldspot-bpf load)")


def cmd_top(args):
    import time
    once = "--once" in args
    try:
        while True:
            st = _status()
            sys.stdout.write("\x1b[2J\x1b[H")   # clear screen, cursor home
            if st is None:
                print("coldspotd not running (no status).")
            else:
                _render_top(st)
            sys.stdout.flush()
            if once:
                break
            time.sleep(2)
    except KeyboardInterrupt:
        pass


def _report_window(period):
    """(sql_condition, params, label) selecting an hour-range from app_usage."""
    import time
    if period == "today":
        d = time.strftime("%Y-%m-%d")
        return "substr(hour,1,10) = ?", (d,), f"today ({d})"
    if period == "week":
        wk = time.strftime("%Y-%m-%d", time.localtime(time.time() - 6 * 86400))
        return "substr(hour,1,10) >= ?", (wk,), f"last 7 days (since {wk})"
    ym = time.strftime("%Y-%m")
    return "substr(hour,1,7) = ?", (ym,), f"this month ({ym})"


def cmd_report(args):
    import sqlite3
    period = next((a for a in args if a in ("today", "week", "month")), "month")
    cond, params, label = _report_window(period)
    try:
        db = sqlite3.connect(f"file:{TS_DB}?mode=ro", uri=True)
    except sqlite3.OperationalError:
        sys.exit("no time-series yet — needs the bpf core and a running daemon.")
    try:
        by_conn = db.execute(
            f"SELECT connection, SUM(rx), SUM(tx), MAX(metered) FROM app_usage "
            f"WHERE {cond} GROUP BY connection "
            f"ORDER BY SUM(rx)+SUM(tx) DESC", params).fetchall()
        by_app = db.execute(
            f"SELECT app, SUM(rx), SUM(tx) FROM app_usage WHERE {cond} "
            f"GROUP BY app ORDER BY SUM(rx)+SUM(tx) DESC LIMIT 15", params).fetchall()
    except sqlite3.OperationalError:
        sys.exit("no time-series yet — needs the bpf core and a running daemon.")
    finally:
        db.close()
    if "--json" in args:
        print(json.dumps({"period": period,
                          "connections": [{"connection": c, "metered": bool(m),
                                           "rx_mb": round(rx / 1e6, 1),
                                           "tx_mb": round(tx / 1e6, 1)}
                                          for c, rx, tx, m in by_conn],
                          "apps": [{"app": a, "rx_mb": round(rx / 1e6, 1),
                                    "tx_mb": round(tx / 1e6, 1)}
                                   for a, rx, tx in by_app]}, indent=2))
        return
    if not by_conn:
        print(f"report — {label}: no data yet.")
        return
    print(f"report — {label}    ↑up / ↓down")
    print("by connection:")
    for c, rx, tx, m in by_conn:
        flag = "M" if m else " "
        print(f"  {(rx + tx) / 1e6:>9.1f} MB  ↑{tx / 1e6:>8.1f} ↓{rx / 1e6:>8.1f}"
              f"  {flag} {c}")
    print("by app:")
    for a, rx, tx in by_app:
        print(f"  {(rx + tx) / 1e6:>9.1f} MB  ↑{tx / 1e6:>8.1f} ↓{rx / 1e6:>8.1f}"
              f"  {a}")


def cmd_history(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    hist = st.get("history") or {}
    if "--json" in args:
        print(json.dumps(hist, indent=2))
        return
    if not hist:
        print("no per-connection history yet.")
        return
    # busiest this month first; a 'M' marks the metered links (the ones that cost)
    rows = sorted(hist.items(), key=lambda kv: kv[1].get("month_mb", 0), reverse=True)
    print(f"{'today':>9} ({'↑':>6}/{'↓':>6})  {'month':>9}   connection")
    for name, rec in rows:
        flag = "M" if rec.get("metered") else " "
        print(f"{rec.get('today_mb', 0):>8.1f} ({rec.get('today_tx_mb', 0):>6.1f}/"
              f"{rec.get('today_rx_mb', 0):>6.1f})  {rec.get('month_mb', 0):>8.1f}  "
              f"{flag} {name}")


def cmd_ledger(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    led = st.get("ledger") or []
    if "--json" in args:
        print(json.dumps(led, indent=2))
        return
    if not led:
        print("no ledger yet — needs the bpf core (sudo coldspot-bpf load).")
        return
    print("today — what ate your data:    ↑up / ↓down")
    for e in led:
        up, dn = e.get("tx_mb", 0), e.get("rx_mb", 0)
        print(f"  {e['mb']:>8.1f} MB  ↑{up:>7.1f} ↓{dn:>7.1f}  {e['name']}")


def cmd_advise(args):
    st = _status()
    if st is None:
        sys.exit("coldspotd not running (no status).")
    adv = st.get("advice") or []
    if "--json" in args:
        print(json.dumps(adv, indent=2))
        return
    if not adv:
        print("nothing to flag — no heavy uploads or seeding right now.")
        return
    for a in adv:
        print(f"⚠ {a.get('hint')}")


def cmd_stance(args):
    if not args or args[0] not in STANCES:
        sys.exit(f"usage: coldspot stance <{'|'.join(STANCES)}>")
    name = args[0]
    _helper("stance", name)    # enforcement first — never depends on the daemon
    try:                       # then update the meter (best-effort)
        _sock({"cmd": "set", "stance": name})
    except OSError:
        pass
    print(f"stance -> {name}")


def cmd_budget(args):
    if not args:
        sys.exit("usage: coldspot budget <MB|off>")
    if args[0] == "off":
        _set(budget=None)
        print("budget -> off")
        return
    try:
        mb = int(args[0])
    except ValueError:
        sys.exit("budget must be an integer number of MB, or 'off'")
    _set(budget=mb)
    print(f"budget -> {mb} MB")


def cmd_allow(args):
    if not args:
        sys.exit("usage: coldspot allow <pid|name>")
    sys.exit(_helper("allow", args[0]))


def cmd_run(args):
    if not args:
        sys.exit("usage: coldspot run -- <cmd...>")
    if args and args[0] == "--":
        args = args[1:]
    sys.exit(_helper("run", *args))


def cmd_reset(args):
    scope = args[0] if args else "session"
    try:
        _sock({"cmd": "reset", "scope": scope})
    except OSError as e:
        sys.exit(f"cannot reach coldspotd ({e})")
    print(f"reset -> {scope}")


def cmd_update(args):
    """Delegate to coldspot-update (next to us or on PATH). --check/--json pass
    through; a bare `update` installs in place via sudo when newer."""
    check = "--check" in args or "--json" in args
    for u in (os.path.join(HERE, "coldspot-update"), "coldspot-update"):
        try:
            # the installer re-execs with sudo itself; --check/--json never need root
            cmd = ([] if (check or os.geteuid() == 0) else ["sudo"]) + [u, *args]
            sys.exit(subprocess.call(cmd))
        except FileNotFoundError:
            continue
    sys.exit("coldspot-update not found; reinstall coldspot.")


def cmd_version(args):
    for p in (os.path.join(HERE, "..", "share", "coldspot", "VERSION"),
              "/usr/local/share/coldspot/VERSION",
              "/usr/share/coldspot/VERSION",
              os.path.join(HERE, "..", "VERSION")):
        try:
            print("coldspot", open(p).read().strip())
            return
        except OSError:
            continue
    print("coldspot (unknown version)")


def main():
    argv = sys.argv[1:]
    if not argv or argv[0] in ("help", "-h", "--help"):
        print(__doc__.strip())
        return
    verb, rest = argv[0], argv[1:]
    table = {
        "status": cmd_status, "flows": cmd_flows, "stance": cmd_stance,
        "top": cmd_top,
        "history": cmd_history, "ledger": cmd_ledger, "advise": cmd_advise,
        "report": cmd_report,
        "budget": cmd_budget, "allow": cmd_allow, "run": cmd_run,
        "reset": cmd_reset, "version": cmd_version,
        "update": cmd_update, "check-update": lambda a: cmd_update(["--check", *a]),
        "siege": lambda a: cmd_stance(["siege"]),
        "cold": lambda a: cmd_stance(["cold"]),
        "open": lambda a: cmd_stance(["open"]),   # panic release
    }
    fn = table.get(verb)
    if not fn:
        sys.exit(f"unknown verb '{verb}' (try: coldspot help)")
    fn(rest)


if __name__ == "__main__":
    main()
