#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-or-later
# coldspot-stance — privileged enforcement helper (nft + cgroup + metered flag).
#
# The meter (coldspotd) only measures; this is the only piece that needs root.
# siege uses a cgroup-v2 allowlist so "everything except the active task" needs
# no per-app firewall rules — the active task lives in coldspot.slice and the
# nft cgroup match passes only that subtree.
set -euo pipefail

SLICE="coldspot.slice"
CG="/sys/fs/cgroup/${SLICE}"
PIN="/sys/fs/bpf/coldspot"
# systemd units `lean` pauses (data hogs). Override in /etc/coldspot.conf:
#   lean_hogs = packagekit snapd fwupd-refresh ...
HOGS=(packagekit snapd fwupd-refresh unattended-upgrades)
_conf_hogs="$(sed -n 's/^[[:space:]]*lean_hogs[[:space:]]*=[[:space:]]*//p' /etc/coldspot.conf 2>/dev/null | tail -1)"
[[ -n "$_conf_hogs" ]] && read -ra HOGS <<<"$_conf_hogs"
SELFDIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
BPF_HELPER="$SELFDIR/coldspot-bpf"

require_root() { [[ $EUID -eq 0 ]] || { echo "coldspot-stance: needs root" >&2; exit 1; }; }

bpf_loaded() { [[ -e "$PIN/policy" ]]; }
slice_level() { awk -F/ '{print NF-4}' <<<"$CG"; }  # /sys/fs/cgroup/X -> 1

# cold-stance egress floor in bytes/sec. "cripple almost" — default ~32 KiB/s
# (~256 kbit/s): enough that nothing fully stalls, clearly throttled. Override
# in /etc/coldspot.conf:  cold_floor_bps = 16384
cold_floor() {
  local f
  f="$(sed -n 's/^[[:space:]]*cold_floor_bps[[:space:]]*=[[:space:]]*//p' /etc/coldspot.conf 2>/dev/null | tail -1)"
  [[ "$f" =~ ^[0-9]+$ ]] && echo "$f" || echo 32768
}

# cold total egress cap in BITS/sec for the CAKE shaper (the whole pipe under
# cold). Default 2 Mbit (~250 KB/s): claude stays usable, bulk crawls. The cap
# protects the budget; warmed tasks just get priority WITHIN it (so even a runaway
# agent swarm can't exceed it). Override:  cold_cap_bits = 1000000
cold_cap_bits() {
  local v
  v="$(sed -n 's/^[[:space:]]*cold_cap_bits[[:space:]]*=[[:space:]]*//p' /etc/coldspot.conf 2>/dev/null | tail -1)"
  [[ "$v" =~ ^[0-9]+$ ]] && echo "$v" || echo 2000000
}

default_iface() { ip route 2>/dev/null | awk '/^default/{print $5; exit}'; }

# Point the bpf core at the coldspot.slice subtree as the siege survivor. The
# core matches by ANCESTOR id, so every descendant (run-*.scope, loose) survives
# even though each has its own cgroup id.
bpf_set_siege_target() {
  bpf_loaded || return 0
  ensure_cgroup
  local cgid; cgid="$(stat -c %i "$CG" 2>/dev/null || true)"
  [[ -n "$cgid" ]] && "$BPF_HELPER" allow "$cgid" "$(slice_level)" || true
}

# When the v1 core is loaded it is the enforcer: flip the policy slot and, for
# siege, point it at the survivor subtree.
bpf_apply() {
  "$BPF_HELPER" stance "$1"
  local oifc; oifc="$(default_iface)"
  # entering ANY stance lifts a prior stabilize overlay's ingress IFB (else it
  # survives `coldspot open`/`cold`); open/lean/siege additionally drop the
  # egress CAKE cap + QoS marking (cold replaces that with its own).
  [[ -n "$oifc" ]] && shaper_ingress_clear "$oifc"
  if [[ "$1" != "3" ]]; then
    [[ -n "$oifc" ]] && shaper_clear "$oifc"
  fi
  # siege (2) and cold (3) both honour the warmed-task subtree.
  if [[ "$1" == "2" || "$1" == "3" ]]; then bpf_set_siege_target; fi
  if [[ "$1" == "3" ]]; then
    # Cold prefers the smooth CAKE cap + warmed priority; only if tc/CAKE is
    # unavailable do we fall back to the crude BPF token-bucket floor.
    local ifc; ifc="$(default_iface)"
    if [[ -n "$ifc" ]] && shaper_setup "$ifc" "$(cold_cap_bits)"; then
      "$BPF_HELPER" throttle 0 0                       # CAKE shapes; BPF fails open
    else
      local floor; floor="$(cold_floor)"
      "$BPF_HELPER" throttle "$floor" "$((floor * 2))"  # fallback: BPF floor
    fi
  fi
}

ensure_cgroup() {
  [[ -d $CG ]] || mkdir -p "$CG"
  # make sure +memory/+pids etc. is irrelevant here; we only need the dir to exist
}

nft_open() {
  nft list table inet coldspot >/dev/null 2>&1 && nft delete table inet coldspot || true
}

nft_siege() {
  ensure_cgroup
  nft delete table inet coldspot 2>/dev/null || true
  nft -f - <<EOF
table inet coldspot {
  chain out {
    type filter hook output priority 0; policy drop;
    ct state established,related accept
    meta l4proto udp udp dport 53 accept
    meta l4proto tcp tcp dport 53 accept
    oif "lo" accept
    socket cgroupv2 level 1 "$SLICE" accept
  }
}
EOF
}

# Fallback throttle when the bpf core isn't loaded: a global egress rate limit.
# Coarser than the bpf token bucket (it's one limiter for everything, and the
# warmed task shares it), but it keeps the cold posture working without the core.
nft_cold() {
  ensure_cgroup
  local kb=$(( ${1:-32768} / 1024 ))
  [[ $kb -lt 1 ]] && kb=1
  nft delete table inet coldspot 2>/dev/null || true
  nft -f - <<EOF
table inet coldspot {
  chain out {
    type filter hook output priority 0; policy accept;
    oif "lo" accept
    meta l4proto udp udp dport 53 accept
    meta l4proto tcp tcp dport 53 accept
    socket cgroupv2 level 1 "$SLICE" accept
    limit rate over ${kb} kbytes/second drop
  }
}
EOF
}

# Smooth system-wide EGRESS cap (the "1 MB/s, spend it wisely" pipe). CAKE is the
# right tool: one qdisc that shapes to the bandwidth accurately (it gets the
# burst/quantum math right where hand-tuned HTB badly under-delivers on wifi) AND
# does per-flow fairness for free, so no single connection hogs the trickle.
# Falls back to a single-class HTB with a generous burst if sch_cake is absent.
# Per-app priority / caps + ingress download policing land in task #20.
# Priority within the cap: mark warmed (coldspot.slice) + DNS egress with a high
# DSCP (CS5). CAKE runs diffserv3, which maps CS5 to its latency-sensitive tin, so
# warmed traffic is served BEFORE bulk — claude stays responsive while a runaway
# pull/website/swarm gets only the leftover. Everything stays under the total cap.
nft_qos() {
  nft delete table inet coldspot_qos 2>/dev/null || true
  nft -f - <<EOF
table inet coldspot_qos {
  chain out {
    type filter hook output priority mangle; policy accept;
    socket cgroupv2 level 1 "$SLICE" ip dscp set cs5
    socket cgroupv2 level 1 "$SLICE" ip6 dscp set cs5
    udp dport 53 ip dscp set cs5
    udp dport 53 ip6 dscp set cs5
    tcp dport 53 ip dscp set cs5
    tcp dport 53 ip6 dscp set cs5
  }
}
EOF
}
nft_qos_clear() { nft delete table inet coldspot_qos 2>/dev/null || true; }

shaper_setup() {
  local iface="$1" bits="$2"
  if tc qdisc replace dev "$iface" root cake bandwidth "${bits}bit" diffserv3 2>/dev/null; then
    nft_qos 2>/dev/null || true   # warmed/DNS -> priority tin
    return 0
  fi
  local burst=$(( bits / 800 )); [[ $burst -lt 1600 ]] && burst=1600   # ~10ms of rate
  tc qdisc replace dev "$iface" root handle 1: htb default 1 || return 1
  tc class replace dev "$iface" parent 1: classid 1:1 \
    htb rate "${bits}bit" ceil "${bits}bit" burst "${burst}b" cburst "${burst}b"
  tc qdisc replace dev "$iface" parent 1:1 handle 10: fq_codel 2>/dev/null || true
}

shaper_clear() {
  nft_qos_clear
  tc qdisc del dev "$1" root 2>/dev/null || true
}

# ---- stabilize: weak/lossy-link tuning (the layer-1/2 response) -------------
# cold protects a DATA BUDGET (a hard low cap). stabilize protects LATENCY on a
# BAD link: cap just under the real ceiling, thin ACKs (a weak uplink chokes on
# them and starves the downlink), tell CAKE the honest RTT, and — the big win —
# shape the DOWNLOAD via an IFB mirror so inbound bufferbloat can't build. The
# shared nft_qos still gives warmed tasks + DNS the priority tin. Power-save off
# because it makes a weak link miss beacons and drop.
IFB="ifb-cs"

stabilize_egress() {   # $1 iface  $2 ul_bits
  local iface="$1" ul="$2"
  if tc qdisc replace dev "$iface" root cake bandwidth "${ul}bit" diffserv3 \
       ack-filter rtt 100ms 2>/dev/null; then
    nft_qos 2>/dev/null || true
    return 0
  fi
  tc qdisc replace dev "$iface" root fq_codel 2>/dev/null || return 1
}

shaper_ingress_setup() {   # $1 iface  $2 dl_bits — download-side AQM via IFB
  local iface="$1" dl="$2"
  modprobe ifb numifbs=0 2>/dev/null || modprobe ifb 2>/dev/null || true
  ip link show "$IFB" >/dev/null 2>&1 || ip link add "$IFB" type ifb || return 1
  ip link set "$IFB" up
  tc qdisc replace dev "$iface" handle ffff: ingress 2>/dev/null || return 1
  tc filter replace dev "$iface" parent ffff: protocol all matchall \
       action mirred egress redirect dev "$IFB" 2>/dev/null \
    || tc filter replace dev "$iface" parent ffff: protocol all u32 \
         match u32 0 0 action mirred egress redirect dev "$IFB" || return 1
  tc qdisc replace dev "$IFB" root cake bandwidth "${dl}bit" besteffort ingress \
    2>/dev/null || tc qdisc replace dev "$IFB" root fq_codel
}

shaper_ingress_clear() {   # $1 iface
  tc qdisc del dev "$1" handle ffff: ingress 2>/dev/null || true
  tc qdisc del dev "$IFB" root 2>/dev/null || true
  ip link del "$IFB" 2>/dev/null || true
}

stabilize_setup() {   # $1 iface  $2 ul_bits  $3 dl_bits
  local iface="$1" ul="$2" dl="$3"
  iw dev "$iface" set power_save off 2>/dev/null || true
  stabilize_egress "$iface" "$ul"
  shaper_ingress_setup "$iface" "$dl" || true
}

stabilize_clear() {   # $1 iface
  shaper_clear "$1"             # egress cake + nft_qos
  shaper_ingress_clear "$1"
}

pause_hogs() { for u in "${HOGS[@]}"; do systemctl stop "$u" 2>/dev/null || true; done; }

case "${1:-}" in
  stance)
    require_root
    case "${2:-}" in open) n=0;; lean) n=1;; siege) n=2;; cold) n=3;;
      *) echo "usage: coldspot-stance stance <open|lean|siege|cold>" >&2; exit 1 ;;
    esac
    if bpf_loaded; then
      # v1: the kernel core enforces; nft stays out of the way.
      [[ $n == 1 ]] && pause_hogs
      [[ $n == 3 ]] && pause_hogs   # cold also stops the background hogs outright
      [[ $n == 0 ]] && command -v tailscale >/dev/null && tailscale up >/dev/null 2>&1 || true
      bpf_apply "$n"
      echo "enforcement: ${2} (bpf core)"
    else
      case "$2" in
        open)
          nft_open
          command -v tailscale >/dev/null && tailscale up >/dev/null 2>&1 || true
          echo "enforcement: open (all traffic permitted)"
          ;;
        lean)
          nft_open
          pause_hogs
          command -v tailscale >/dev/null && tailscale down >/dev/null 2>&1 || true
          echo "enforcement: lean (hogs paused, tailscale down)"
          ;;
        siege)
          pause_hogs
          nft_siege
          echo "enforcement: siege (only $SLICE on the wire)"
          ;;
        cold)
          pause_hogs
          nft_cold "$(cold_floor)"
          echo "enforcement: cold (egress throttled; nft fallback, no bpf core)"
          ;;
      esac
    fi
    ;;
  limit)
    require_root
    iface="${2:?usage: coldspot-stance limit <iface> <bits_per_sec>}"
    bits="${3:?usage: coldspot-stance limit <iface> <bits_per_sec>}"
    shaper_setup "$iface" "$bits"
    echo "limit: ${iface} egress capped at ${bits} bit/s"
    ;;
  unlimit)
    require_root
    iface="${2:?usage: coldspot-stance unlimit <iface>}"
    shaper_clear "$iface"
    echo "limit cleared on ${iface}"
    ;;
  stabilize)
    require_root
    iface="${2:?usage: coldspot-stance stabilize <iface> <ul_bits> [dl_bits]}"
    ul="${3:?usage: coldspot-stance stabilize <iface> <ul_bits> [dl_bits]}"
    dl="${4:-$ul}"
    stabilize_setup "$iface" "$ul" "$dl"
    echo "stabilize: ${iface} ul<=${ul} dl<=${dl} bit/s (ack-filter + ingress AQM + priority)"
    ;;
  unstabilize)
    require_root
    iface="${2:?usage: coldspot-stance unstabilize <iface>}"
    stabilize_clear "$iface"
    echo "stabilize cleared on ${iface}"
    ;;
  allow)
    require_root; ensure_cgroup
    pid="${2:?usage: coldspot-stance allow <pid>}"
    # cgroup v2 forbids processes in a cgroup that has child cgroups, so loose
    # pids go in a leaf sub-cgroup of the slice (still covered by the subtree).
    mkdir -p "$CG/loose"
    echo "$pid" > "$CG/loose/cgroup.procs"
    bpf_set_siege_target
    echo "allowed: pid $pid -> $SLICE/loose"
    ;;
  run)
    require_root; ensure_cgroup; shift
    bpf_set_siege_target   # refresh the survivor subtree before launching
    exec systemd-run --slice="$SLICE" --scope --quiet -- "$@"
    ;;
  *)
    echo "usage: coldspot-stance <stance|limit|unlimit|allow|run> ..." >&2; exit 1 ;;
esac
