#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026 asuramaya and coldspot contributors
"""coldspotd — meters the cold link and publishes per-app truth.

v0 sources, in order of fidelity (each degrades to the next):
  1. systemd per-unit IP accounting  -> per-app rx/tx        (needs IPAccounting)
  2. /proc/net/dev on the metered iface -> interface total   (always works)

The control socket flips stance / budget; the BPF core (bpf/coldspot.bpf.c)
replaces source #1 at v1 with fused metering + siege verdict. Userspace seam
(the status.json the CLI and panel read) does not change when that lands.
"""
import glob
import json
import os
import re
import socket
import sqlite3
import subprocess
import time

RUN = "/run/coldspot"
STATE = "/var/lib/coldspot"
SOCK = f"{RUN}/control.sock"
STATUS = f"{RUN}/status.json"
DAY_DB = f"{STATE}/usage.json"
HISTORY_DB = f"{STATE}/history.json"  # per-connection daily/monthly rollups
LEDGER_DB = f"{STATE}/ledger.json"    # per-day per-app bytes (survives reloads)
TS_DB = f"{STATE}/coldspot.db"        # hourly (connection, app) time-series
BPF_USAGE = "/sys/fs/bpf/coldspot/usage"  # v1 core's per-cgroup map (if loaded)
BPF_FLOWS = "/sys/fs/bpf/coldspot/flows"  # per-destination breakdown (if loaded)
BPF_DNS = "/sys/fs/bpf/coldspot/dns"      # captured DNS responses (if loaded)
BPF_PROC = "/sys/fs/bpf/coldspot/proc_usage"  # per-process bytes (if loaded)
BPF_CFG = "/sys/fs/bpf/coldspot/cfg"      # metered ifindex (set by us, if loaded)
BPF_CRITICAL = "/sys/fs/bpf/coldspot/critical"  # never-throttle service cgroups
CONF = "/etc/coldspot.conf"
SAMPLE = 2.0  # seconds between samples
HERE = os.path.dirname(os.path.realpath(__file__))

STANCES = ("open", "lean", "siege", "cold")


def metered_iface():
    """The device NetworkManager flagged metered (your 'Brick'), else env/guess."""
    if os.environ.get("COLDSPOT_IFACE"):
        return os.environ["COLDSPOT_IFACE"]
    try:
        out = subprocess.run(
            ["nmcli", "-t", "-f", "GENERAL.IP-IFACE,GENERAL.METERED", "device", "show"],
            capture_output=True, text=True, timeout=3).stdout
        iface = None
        for line in out.splitlines():
            if line.startswith("GENERAL.IP-IFACE:"):
                iface = line.split(":", 1)[1].strip()
            elif line.startswith("GENERAL.METERED:") and "yes" in line and iface:
                return iface
    except Exception:
        pass
    # fall back to the first wireless device that is up
    for d in sorted(glob.glob("/sys/class/net/wl*")):
        return os.path.basename(d)
    return "lo"


def _link_state(iface):
    """(is_metered, connection_name) for the iface, live from NetworkManager.
    Same wifi adapter carries both metered (Brick) and unmetered (home) networks,
    so we gate accounting on the *connection's* metered flag, not the interface."""
    if iface == "lo":
        return False, ""
    try:
        out = subprocess.run(
            ["nmcli", "-t", "-f", "GENERAL.METERED,GENERAL.CONNECTION",
             "device", "show", iface],
            capture_output=True, text=True, timeout=2).stdout
        metered, conn = False, ""
        for line in out.splitlines():
            if line.startswith("GENERAL.METERED:"):
                metered = "yes" in line.split(":", 1)[1]
            elif line.startswith("GENERAL.CONNECTION:"):
                conn = line.split(":", 1)[1].strip()
        return metered, conn
    except Exception:
        return False, ""


def read_iface(iface):
    """rx_bytes, tx_bytes for one iface from /proc/net/dev (or None)."""
    try:
        with open("/proc/net/dev") as f:
            for line in f:
                name, _, rest = line.partition(":")
                if name.strip() == iface:
                    c = rest.split()
                    return int(c[0]), int(c[8])
    except OSError:
        pass
    return None


def _le(arr):
    """little-endian byte list (bpftool -j) -> int."""
    v = 0
    for i, b in enumerate(arr):
        v |= int(b, 16) << (8 * i)
    return v


def _cgroup_index():
    """cgroup id (== dir inode) -> leaf name, walking the unified hierarchy."""
    idx = {}
    for root, _dirs, _files in os.walk("/sys/fs/cgroup"):
        try:
            idx[os.stat(root).st_ino] = os.path.basename(root) or "root"
        except OSError:
            pass
    return idx


def _rxtx(val, fmt):
    """(rx, tx) bytes from a bpftool `struct bytes` value in any of the shapes
    bpftool emits across versions. None if it doesn't look like one."""
    if isinstance(val, dict):
        return int(val.get("rx", 0) or 0), int(val.get("tx", 0) or 0)
    if isinstance(fmt.get("value"), dict):
        v = fmt["value"]
        return int(v.get("rx", 0) or 0), int(v.get("tx", 0) or 0)
    if isinstance(val, list) and len(val) >= 16:
        return _le(val[0:8]), _le(val[8:16])
    return None


def _talkers(agg, n=12):
    """{name: [rx, tx]} -> sorted [{name, rx_mb, tx_mb, mb}]. `mb` (combined) is
    kept for older pill builds; rx_mb/tx_mb are the direction split."""
    out = [{"name": name, "rx_mb": round(rx / 1e6, 1), "tx_mb": round(tx / 1e6, 1),
            "mb": round((rx + tx) / 1e6, 1)} for name, (rx, tx) in agg.items()]
    out.sort(key=lambda t: t["mb"], reverse=True)
    return out[:n]


def read_bpf_usage():
    """Per-app rx/tx from the v1 BPF `usage` map. None if the core isn't loaded.

    This is the preferred source: it attributes by cgroup id with no per-process
    sampling, and the same program enforces siege. Falls through to systemd.
    """
    if not os.path.exists(BPF_USAGE):
        return None
    try:
        rows = json.loads(subprocess.run(
            ["bpftool", "map", "dump", "pinned", BPF_USAGE, "-j"],
            capture_output=True, text=True, timeout=3).stdout)
    except Exception:
        return None
    idx = _cgroup_index()
    agg = {}
    for r in rows:
        key, val = r.get("key"), r.get("value")
        cgid = _le(key) if isinstance(key, list) else int(key) if key else None
        rxtx = _rxtx(val, r.get("formatted") or {})
        if cgid is None or rxtx is None or (rxtx[0] + rxtx[1]) <= 0:
            continue
        name = _pretty(idx.get(cgid, f"cg:{cgid}"))
        e = agg.setdefault(name, [0, 0])
        e[0] += rxtx[0]
        e[1] += rxtx[1]
    return _talkers(agg)


def _dns_name(buf, off):
    """Read a DNS name starting at off, following compression pointers.
    Returns (name, offset_after_name_in_stream)."""
    labels = []
    jumped = False
    end = off
    steps = 0
    while off < len(buf) and steps < 128:
        steps += 1
        ln = buf[off]
        if ln == 0:
            off += 1
            break
        if ln & 0xC0 == 0xC0:  # pointer
            if off + 1 >= len(buf):
                break
            if not jumped:
                end = off + 2
            off = ((ln & 0x3F) << 8) | buf[off + 1]
            jumped = True
            continue
        off += 1
        labels.append(buf[off:off + ln].decode("ascii", "replace"))
        off += ln
    return ".".join(labels), (end if jumped else off)


def _parse_dns(buf):
    """Best-effort: (queried name, ip) pairs from a DNS response. A + AAAA."""
    out = []
    try:
        if len(buf) < 12 or not (int.from_bytes(buf[2:4], "big") & 0x8000):
            return out  # responses only
        qd = int.from_bytes(buf[4:6], "big")
        an = int.from_bytes(buf[6:8], "big")
        if not qd or not an:
            return out
        _, off = _dns_name(buf, 12)
        off += 4  # qtype + qclass (one question)
        qname = _dns_name(buf, 12)[0]
        for _ in range(min(an, 32)):
            _, off = _dns_name(buf, off)
            if off + 10 > len(buf):
                break
            typ = int.from_bytes(buf[off:off + 2], "big")
            rdlen = int.from_bytes(buf[off + 8:off + 10], "big")
            rd = buf[off + 10:off + 10 + rdlen]
            off += 10 + rdlen
            if typ == 1 and len(rd) == 4:           # A
                out.append((qname, ".".join(str(b) for b in rd)))
            elif typ == 28 and len(rd) == 16:        # AAAA
                out.append((qname, socket.inet_ntop(socket.AF_INET6, rd)))
    except Exception:
        pass
    return out


DNS_TTL = 1800.0  # forget a name if its IP hasn't been re-seen in 30 min


def read_dns_names(cache):
    """Poll the BPF `dns` ring, parse responses, fill cache[ip] = (host, ts)."""
    if not os.path.exists(BPF_DNS):
        return
    try:
        rows = json.loads(subprocess.run(
            ["bpftool", "map", "dump", "pinned", BPF_DNS, "-j"],
            capture_output=True, text=True, timeout=3).stdout)
    except Exception:
        return
    now = time.monotonic()
    for r in rows:
        val = r.get("value")
        if not (isinstance(val, list) and len(val) >= 4):
            continue
        ln = _le(val[0:4])
        if ln <= 0 or 4 + ln > len(val):
            continue
        buf = bytes(int(b, 16) for b in val[4:4 + ln])
        for name, ip in _parse_dns(buf):
            if name:
                cache[ip] = (name, now)
    # expire stale names (recycled IPs), then bound the cache (drop oldest)
    for ip in [k for k, (_, ts) in cache.items() if now - ts > DNS_TTL]:
        del cache[ip]
    if len(cache) > 4096:
        for ip, _ in sorted(cache.items(),
                            key=lambda kv: kv[1][1])[:len(cache) - 4096]:
            del cache[ip]


def _external(ip):
    """True for public destinations. Skip loopback/private/link-local/multicast —
    they don't traverse the metered link, so they're noise in a hotspot view."""
    if ":" in ip:  # IPv6
        low = ip.lower()
        if low in ("::1", "::"):
            return False
        if low[:2] == "ff":                         # multicast
            return False
        if low[:2] in ("fc", "fd"):                 # ULA fc00::/7
            return False
        if low[:3] in ("fe8", "fe9", "fea", "feb"):  # link-local fe80::/10
            return False
        return True
    o = ip.split(".")
    if len(o) != 4:
        return True
    try:
        a, b = int(o[0]), int(o[1])
    except ValueError:
        return True
    if a == 127 or a == 10 or a >= 224 or a == 0:        # loopback, 10/8, mcast
        return False
    if a == 172 and 16 <= b <= 31:                        # 172.16/12
        return False
    if a == 192 and b == 168:                             # 192.168/16
        return False
    if a == 169 and b == 254:                             # link-local
        return False
    return True


def read_flows_raw(names=None):
    """All external flows from the v1 BPF `flows` map. None if the core isn't
    loaded. Each entry carries rx+tx (`mb`) and upload alone (`tx_mb`) — the
    advisor needs upload separated to spot seeding.

    Decodes the 40-byte flow_key (comm|ip|port|proto|family) from raw bytes —
    robust across bpftool versions that may or may not emit a `formatted` block.
    """
    if not os.path.exists(BPF_FLOWS):
        return None
    try:
        rows = json.loads(subprocess.run(
            ["bpftool", "map", "dump", "pinned", BPF_FLOWS, "-j"],
            capture_output=True, text=True, timeout=3).stdout)
    except Exception:
        return None
    out = []
    for r in rows:
        key, val = r.get("key"), r.get("value")
        if not (isinstance(key, list) and len(key) >= 37):
            continue
        if not (isinstance(val, list) and len(val) >= 16):
            continue
        comm = bytes(int(b, 16) for b in key[0:16]).split(b"\x00")[0].decode(
            "ascii", "replace") or "?"
        fam = int(key[36], 16)
        ipb = bytes(int(b, 16) for b in key[16:32])
        if fam == 6:
            ip = socket.inet_ntop(socket.AF_INET6, ipb)
        else:
            ip = ".".join(str(b) for b in ipb[0:4])
        port = _le(key[32:34])
        proto = _le(key[34:36])
        tx = _le(val[8:16])
        mb = (_le(val[0:8]) + tx) / 1e6
        if mb <= 0 or not _external(ip):
            continue
        ent = (names or {}).get(ip)
        out.append({"app": comm,
                    "dst": ip, "host": ent[0] if ent else None, "port": port,
                    "proto": {6: "tcp", 17: "udp"}.get(proto, str(proto)),
                    "mb": round(mb, 1), "tx_mb": round(tx / 1e6, 1)})
    out.sort(key=lambda f: f["mb"], reverse=True)
    return out


def read_flows(names=None):
    """Top external destinations for the flows display. None if unloaded."""
    full = read_flows_raw(names)
    return None if full is None else full[:20]


# ---- name connections that predate the core load --------------------------
# The connect hook only fires on NEW connections, so anything already open when
# the core loads has no owner in the cookie map and shows as `?`. We can't seed
# the cookie-keyed BPF map from userspace (socket cookies aren't exposed for
# foreign sockets), so resolve `?` flows the way `ss` does: remote tuple ->
# socket inode (/proc/net/{tcp,udp}*) -> pid (/proc/*/fd) -> process name.

def _hex_to_ip_port(token, v6):
    """'0100007F:0050' -> ('127.0.0.1', 80). /proc/net prints each 32-bit word
    in CPU order, so recover network bytes by reversing within each 4-byte word
    (v4 = one word, v6 = four)."""
    addr, _, port = token.partition(":")
    raw = bytes.fromhex(addr)
    net = b"".join(raw[i:i + 4][::-1] for i in range(0, len(raw), 4))
    fam = socket.AF_INET6 if v6 else socket.AF_INET
    return socket.inet_ntop(fam, net), int(port, 16)


def _parse_proc_net(text, v6):
    """[(remote_ip, remote_port, inode)] from a /proc/net/{tcp,udp}* dump."""
    out = []
    for line in text.splitlines()[1:]:   # skip the header row
        f = line.split()
        if len(f) < 10:
            continue
        try:
            rip, rport = _hex_to_ip_port(f[2], v6)   # col 2 = rem_address
            out.append((rip, rport, int(f[9])))      # col 9 = socket inode
        except Exception:
            continue
    return out


def _socket_inode_pids():
    """{socket_inode: comm} by scanning /proc/*/fd for socket:[inode] links."""
    out = {}
    for pid in os.listdir("/proc"):
        if not pid.isdigit():
            continue
        fddir = f"/proc/{pid}/fd"
        comm = None
        try:
            fds = os.listdir(fddir)
        except OSError:
            continue
        for fd in fds:
            try:
                target = os.readlink(f"{fddir}/{fd}")
            except OSError:
                continue
            if target.startswith("socket:["):
                ino = int(target[8:-1])
                if ino in out:
                    continue
                if comm is None:
                    try:
                        comm = open(f"/proc/{pid}/comm").read().strip() or pid
                    except OSError:
                        comm = pid
                out[ino] = comm
    return out


def flow_owner_index():
    """{(proto, remote_ip, remote_port): comm} resolving live endpoints to their
    owning process (like `ss`). The inode->pid scan is built lazily, only if a
    socket actually needs resolving."""
    idx = {}
    inode_pid = None
    for fname, v6 in (("tcp", False), ("tcp6", True), ("udp", False), ("udp6", True)):
        proto = "tcp" if fname.startswith("tcp") else "udp"
        try:
            text = open(f"/proc/net/{fname}").read()
        except OSError:
            continue
        for rip, rport, inode in _parse_proc_net(text, v6):
            if not inode:
                continue
            if inode_pid is None:
                inode_pid = _socket_inode_pids()
            comm = inode_pid.get(inode)
            if comm:
                idx[(proto, rip, rport)] = comm
    return idx


def enrich_unknown_flows(flows):
    """Replace `?` (pre-existing connection) with the resolved process name.
    No-op — and no /proc scan — when nothing is unknown."""
    if not any(f.get("app") == "?" for f in flows):
        return flows
    idx = flow_owner_index()
    for f in flows:
        if f.get("app") == "?":
            comm = idx.get((f["proto"], f["dst"], f["port"]))
            if comm:
                f["app"] = comm
    return flows


def advise(flows_full, conf):
    """Spot data-hungry patterns worth a proactive nudge, returned as a list of
    advisories. The headline one is P2P seeding: a single app fanning sustained
    *upload* out to many distinct external peers — caught Transmission seeding
    ~11 GB live, and unlike a single big download it's usually unintended on a
    hotspot. Thresholds are tunable in /etc/coldspot.conf."""
    if not conf.get("advise", True):
        return []
    tx_min = float(conf.get("advise_tx_mb", 200))
    peer_min = int(conf.get("advise_peers", 8))
    agg = {}   # app -> [tx_mb_sum, {peers}]
    for f in flows_full or []:
        tx = f.get("tx_mb", 0) or 0
        if tx <= 0:
            continue
        a = agg.setdefault(f.get("app") or "?", [0.0, set()])
        a[0] += tx
        a[1].add(f.get("host") or f.get("dst"))
    out = []
    for app, (tx_sum, peers) in agg.items():
        if tx_sum >= tx_min and len(peers) >= peer_min:
            out.append({
                "app": app, "kind": "seeding",
                "tx_mb": round(tx_sum, 1), "peers": len(peers),
                "hint": f"{app} is uploading {round(tx_sum)} MB to "
                        f"{len(peers)} peers — looks like P2P seeding. "
                        f"`coldspot siege` stops it, or pause the app."})
    out.sort(key=lambda x: x["tx_mb"], reverse=True)
    return out


def load_conf():
    """Tiny key=val config: auto_siege + the advisor knobs."""
    conf = {"auto_siege": False, "advise": True,
            "advise_tx_mb": 200, "advise_peers": 8, "cold_floor_bps": 32768,
            "anomaly": True, "anomaly_factor": 3.0, "anomaly_floor_mb": 200,
            "auto_govern": True, "cold_cap_bits": 2000000}
    try:
        for ln in open(CONF):
            ln = ln.strip()
            if not ln or ln.startswith("#") or "=" not in ln:
                continue
            k, v = (x.strip() for x in ln.split("=", 1))
            if k in ("auto_siege", "advise", "anomaly", "auto_govern"):
                conf[k] = v.lower() in ("1", "true", "yes", "on")
            elif k in ("advise_tx_mb", "advise_peers", "cold_floor_bps",
                       "anomaly_floor_mb", "cold_cap_bits"):
                try:
                    conf[k] = int(v)
                except ValueError:
                    pass
            elif k == "anomaly_factor":
                try:
                    conf[k] = float(v)
                except ValueError:
                    pass
    except OSError:
        pass
    return conf


def enforce(stance):
    """Drive the privileged helper (daemon runs as root system service)."""
    for b in (os.path.join(HERE, "coldspot-stance"), "coldspot-stance"):
        try:
            subprocess.run([b, "stance", stance], timeout=15)
            return True
        except (FileNotFoundError, OSError):
            continue
    return False


_ip_accounting = None


def _ip_accounting_on():
    """Cached check: is systemd IP accounting on at all? If not, skip the
    per-unit `systemctl show` polling entirely — it's the daemon's main idle
    cost and returns nothing when accounting is off (the default)."""
    global _ip_accounting
    if _ip_accounting is None:
        try:
            out = subprocess.run(["systemctl", "show", "-p", "DefaultIPAccounting"],
                                 capture_output=True, text=True, timeout=2).stdout
            _ip_accounting = out.strip().endswith("=yes")
        except Exception:
            _ip_accounting = False
    return _ip_accounting


def set_metered_cfg(iface):
    """Tell the BPF core which ifindex is metered, so accounting + siege apply
    only to that link. Idempotent; no-op if the core isn't loaded."""
    if not os.path.exists(BPF_CFG):
        return
    try:
        idx = socket.if_nametoindex(iface)
    except OSError:
        return
    b = idx.to_bytes(4, "little")
    subprocess.run(["bpftool", "map", "update", "pinned", BPF_CFG,
                    "key", "0", "0", "0", "0", "value",
                    *(f"0x{x:02x}" for x in b)],
                   capture_output=True, timeout=3)


def _bpf_clear_map(path):
    """Delete every key in a pinned BPF hash map — there is no bulk-clear op, so
    dump the keys and delete each. Best-effort; silent if the map isn't there."""
    if not os.path.exists(path):
        return
    try:
        rows = json.loads(subprocess.run(
            ["bpftool", "map", "dump", "pinned", path, "-j"],
            capture_output=True, text=True, timeout=3).stdout)
    except Exception:
        return
    for r in rows:
        key = r.get("key")
        if not isinstance(key, list):
            continue
        subprocess.run(["bpftool", "map", "delete", "pinned", path,
                        "key", *[str(b) for b in key]],
                       capture_output=True, timeout=3)


def bpf_reset_usage():
    """Zero the attribution maps (usage, proc_usage, flows) on a roam.

    The BPF core gates on ifindex, but metered-ness is per-CONNECTION and the
    same adapter carries both Brick (metered) and home (unmetered). The kernel
    can't see the SSID, so when NetworkManager reports a different connection the
    daemon clears these maps — otherwise the previous network's bytes linger in
    talkers/flows and disagree with the connection-gated session/day totals.
    policy/siege/cfg/dns are intentionally left intact."""
    for p in (BPF_USAGE, BPF_PROC, BPF_FLOWS):
        _bpf_clear_map(p)


# Connectivity-critical services that cold must never throttle (matched by
# cgroup id, since they're indistinguishable from other HTTPS by port).
CRITICAL_UNITS = ("NetworkManager.service", "systemd-resolved.service",
                  "systemd-timesyncd.service", "chrony.service",
                  "chronyd.service", "wpa_supplicant.service",
                  "dhcpcd.service", "dhclient.service",
                  "coldspot-update.service", "coldspotd.service")


def set_critical_cgroups():
    """Write connectivity-critical service cgroup ids into the BPF `critical`
    map. Cheap and idempotent; cgroup ids only change when a service restarts,
    so refreshing on the attribution tick is plenty. No-op if the core or the
    units aren't present."""
    if not os.path.exists(BPF_CRITICAL):
        return
    for unit in CRITICAL_UNITS:
        path = f"/sys/fs/cgroup/system.slice/{unit}"
        try:
            cgid = os.stat(path).st_ino
        except OSError:
            continue
        b = cgid.to_bytes(8, "little")
        subprocess.run(["bpftool", "map", "update", "pinned", BPF_CRITICAL,
                        "key", *(f"0x{x:02x}" for x in b), "value", "0x01"],
                       capture_output=True, timeout=3)


def read_proc_raw():
    """{comm: total_bytes} from the BPF `proc_usage` map, full precision.
    None if the core isn't loaded. The basis for both the talker list and the
    persistent ledger (which needs exact cumulative bytes to take deltas)."""
    if not os.path.exists(BPF_PROC):
        return None
    try:
        rows = json.loads(subprocess.run(
            ["bpftool", "map", "dump", "pinned", BPF_PROC, "-j"],
            capture_output=True, text=True, timeout=3).stdout)
    except Exception:
        return None
    out = {}
    for r in rows:
        key, val = r.get("key"), r.get("value")
        if not (isinstance(key, list) and isinstance(val, list) and len(val) >= 16):
            continue
        comm = bytes(int(b, 16) for b in key).split(b"\x00")[0].decode(
            "ascii", "replace")
        rx, tx = _le(val[0:8]), _le(val[8:16])
        if comm and (rx + tx) > 0:
            e = out.setdefault(comm, [0, 0])
            e[0] += rx
            e[1] += tx
    return out


def proc_talkers(raw):
    """Top processes as [{name, rx_mb, tx_mb, mb}] from a read_proc_raw() dict."""
    return _talkers(raw)


def attach_rates(talkers, raw, prev, dt):
    """Add per-app rx_bps/tx_bps from the byte delta since the last attribution
    (what `coldspot top` shows). dt is seconds; a map reset just reads as 0."""
    for t in talkers:
        crx, ctx = raw.get(t["name"], (0, 0))
        prx, ptx = prev.get(t["name"], (0, 0))
        t["rx_bps"] = round(max(0, crx - prx) / dt)
        t["tx_bps"] = round(max(0, ctx - ptx) / dt)


# ---- per-connection history + persistent attribution ledger ----------------
# Two questions the live maps can't answer because they reset on roam/reload:
#   history  — "how much have I used on Brick vs home, today and this month?"
#   ledger   — "what ate today's data?" (survives a core reload / a roam)

def history_add(history, conn, metered, today, drx, dtx):
    """Attribute an interface byte delta to the active connection's day + month.
    The adapter carries exactly one connection at a time, so the /proc/net/dev
    delta belongs wholly to whatever NM reports as current."""
    rec = history.setdefault(conn, {"metered": metered, "days": {}, "months": {}})
    rec["metered"] = metered
    d = rec["days"].setdefault(today, [0, 0]);          d[0] += drx; d[1] += dtx
    m = rec["months"].setdefault(today[:7], [0, 0]);    m[0] += drx; m[1] += dtx


def history_prune(history, keep_days=90, keep_months=24):
    for rec in history.values():
        for bucket, keep in (("days", keep_days), ("months", keep_months)):
            b = rec.get(bucket, {})
            for k in sorted(b)[:max(0, len(b) - keep)]:
                del b[k]


def proc_deltas(prev, cur):
    """{comm: [drx, dtx]} positive byte deltas between two proc_usage snapshots.
    proc_usage is cumulative and is cleared on roam/reload, so a drop (cur < prev)
    is a reset — count the current value as the delta instead of going negative.
    The single source of truth feeding both the JSON ledger and the time-series."""
    out = {}
    for comm, (crx, ctx) in cur.items():
        prx, ptx = prev.get(comm, (0, 0))
        drx = crx - prx if crx >= prx else crx
        dtx = ctx - ptx if ctx >= ptx else ctx
        if drx > 0 or dtx > 0:
            out[comm] = [max(0, drx), max(0, dtx)]
    return out


def ledger_add(ledger, deltas, today):
    """Fold per-app [drx, dtx] deltas into today's ledger entry [rx, tx]."""
    day = ledger.setdefault(today, {})
    for comm, (drx, dtx) in deltas.items():
        e = day.setdefault(comm, [0, 0])
        e[0] += drx
        e[1] += dtx


def ledger_prune(ledger, keep_days=14):
    for k in sorted(ledger)[:max(0, len(ledger) - keep_days)]:
        del ledger[k]


# ---- persistent time-series (SQLite) ---------------------------------------
# The JSON ledger answers "today" but is shallow (14 days, no connection, no
# hour). This is the deep store `coldspot report` queries: one hourly row per
# (connection, app) with rx/tx, so "where did the month go on Brick" and "what
# did claude upload last Tuesday" are answerable. Additive — the JSON path still
# powers status.json; this just accumulates beside it.

def ts_open(path):
    """Open (creating) the time-series DB. Returns a connection, or None if
    sqlite is somehow unavailable — the daemon must never die over telemetry."""
    try:
        db = sqlite3.connect(path)
        db.execute("CREATE TABLE IF NOT EXISTS app_usage ("
                   "hour TEXT, connection TEXT, metered INTEGER, app TEXT, "
                   "rx INTEGER, tx INTEGER, "
                   "PRIMARY KEY (hour, connection, app))")
        db.commit()
        return db
    except Exception:
        return None


def ts_record(db, hour, connection, metered, deltas):
    """Upsert per-app [drx, dtx] deltas into the (hour, connection, app) row."""
    if db is None or not deltas:
        return
    rows = [(hour, connection or "?", 1 if metered else 0, app, d[0], d[1])
            for app, d in deltas.items()]
    try:
        db.executemany(
            "INSERT INTO app_usage (hour, connection, metered, app, rx, tx) "
            "VALUES (?, ?, ?, ?, ?, ?) "
            "ON CONFLICT (hour, connection, app) DO UPDATE SET "
            "rx = rx + excluded.rx, tx = tx + excluded.tx, "
            "metered = excluded.metered", rows)
        db.commit()
    except Exception:
        pass


def ts_prune(db, keep_days=120):
    """Drop rows older than keep_days (compared on the hour's date prefix)."""
    if db is None:
        return
    cutoff = time.strftime("%Y-%m-%d",
                           time.localtime(time.time() - keep_days * 86400))
    try:
        db.execute("DELETE FROM app_usage WHERE substr(hour, 1, 10) < ?", (cutoff,))
        db.commit()
    except Exception:
        pass


def budget_eta(used_b, limit_b, elapsed_s, now_epoch):
    """Epoch when the session will hit its cap at the average pace so far, or
    None if there's no cap / no pace yet. now_epoch if already over."""
    if limit_b <= 0 or elapsed_s <= 0:
        return None
    rem = limit_b - used_b
    if rem <= 0:
        return int(now_epoch)
    avg_bps = used_b / elapsed_s
    if avg_bps <= 0:
        return None
    return int(now_epoch + rem / avg_bps)


def detect_anomalies(db, today, conf):
    """Flag apps using far more today than their learned daily baseline — the
    seeding advisor generalized into learned anomaly detection. Needs a few days
    of history before it will fire, so a fresh DB raises nothing."""
    if db is None or not conf.get("anomaly", True):
        return []
    factor = float(conf.get("anomaly_factor", 3.0))
    floor_b = int(conf.get("anomaly_floor_mb", 200)) * 1_000_000
    min_days = 3
    out = []
    try:
        today_rows = db.execute(
            "SELECT app, SUM(rx + tx) FROM app_usage "
            "WHERE substr(hour,1,10) = ? GROUP BY app", (today,)).fetchall()
        for app, tot in today_rows:
            if tot is None or tot < floor_b:
                continue
            base = db.execute(
                "SELECT substr(hour,1,10) d, SUM(rx + tx) FROM app_usage "
                "WHERE app = ? AND substr(hour,1,10) < ? GROUP BY d",
                (app, today)).fetchall()
            if len(base) < min_days:
                continue
            avg = sum(b[1] for b in base) / len(base)
            if avg <= 0 or tot < avg * factor:
                continue
            out.append({"app": app, "kind": "anomaly",
                        "today_mb": round(tot / 1e6, 1),
                        "baseline_mb": round(avg / 1e6, 1),
                        "hint": f"{app} has used {round(tot / 1e6)} MB today — "
                                f"about {round(tot / avg)}x its usual "
                                f"{round(avg / 1e6)} MB/day."})
    except Exception:
        return []
    out.sort(key=lambda x: x["today_mb"], reverse=True)
    return out


def ts_migrate_ledger(db, ledger):
    """One-time best-effort import of the pre-existing JSON ledger (per-day,
    per-app, no connection) so history isn't lost when the DB first appears.
    Imports into hour=<date>T00, connection='?'. Skips if the DB already has
    rows."""
    if db is None or not ledger:
        return
    try:
        if db.execute("SELECT 1 FROM app_usage LIMIT 1").fetchone():
            return
        rows = []
        for date, apps in ledger.items():
            for app, v in apps.items():
                rx, tx = (v[0], v[1]) if isinstance(v, (list, tuple)) else (0, v)
                rows.append((f"{date}T00", "?", 0, app, rx, tx))
        if rows:
            db.executemany(
                "INSERT OR IGNORE INTO app_usage "
                "(hour, connection, metered, app, rx, tx) VALUES (?,?,?,?,?,?)",
                rows)
            db.commit()
    except Exception:
        pass


def history_summary(history, today):
    """Compact per-connection view for status.json: today + month MB (with the
    ↑/↓ split), metered flag."""
    out = {}
    for conn, rec in history.items():
        dd = rec.get("days", {}).get(today, [0, 0])
        mm = rec.get("months", {}).get(today[:7], [0, 0])
        out[conn] = {"metered": rec.get("metered", False),
                     "today_mb": round((dd[0] + dd[1]) / 1e6, 1),
                     "today_rx_mb": round(dd[0] / 1e6, 1),
                     "today_tx_mb": round(dd[1] / 1e6, 1),
                     "month_mb": round((mm[0] + mm[1]) / 1e6, 1)}
    return out


def ledger_top(ledger, today, n=12):
    """Today's per-app totals with the ↑/↓ split. Tolerates the pre-split schema
    (a bare int) from an older ledger.json."""
    out = []
    for c, v in ledger.get(today, {}).items():
        rx, tx = (v[0], v[1]) if isinstance(v, (list, tuple)) else (0, v)
        out.append({"name": c, "rx_mb": round(rx / 1e6, 1),
                    "tx_mb": round(tx / 1e6, 1), "mb": round((rx + tx) / 1e6, 1)})
    out.sort(key=lambda e: e["mb"], reverse=True)
    return out[:n]


def read_app_usage():
    """Per-app rx/tx from systemd IP accounting. Empty if not enabled.

    v0 fallback for when the BPF core isn't loaded.
    """
    if not _ip_accounting_on():
        return []
    talkers = []
    try:
        units = subprocess.run(
            ["systemctl", "list-units", "--type=scope,service", "--state=running",
             "--no-legend", "--plain", "--full"],
            capture_output=True, text=True, timeout=3).stdout
        names = [ln.split()[0] for ln in units.splitlines() if ln.split()]
        for unit in names:
            show = subprocess.run(
                ["systemctl", "show", unit, "-p", "IPIngressBytes", "-p", "IPEgressBytes"],
                capture_output=True, text=True, timeout=2).stdout
            rx = tx = -1
            for ln in show.splitlines():
                k, _, v = ln.partition("=")
                if k == "IPIngressBytes" and v.isdigit():
                    rx = int(v)
                elif k == "IPEgressBytes" and v.isdigit():
                    tx = int(v)
            if rx > 0 or tx > 0:
                talkers.append({"name": _pretty(unit),
                                "rx_mb": round(max(rx, 0) / 1e6, 1),
                                "tx_mb": round(max(tx, 0) / 1e6, 1),
                                "mb": round((max(rx, 0) + max(tx, 0)) / 1e6, 1)})
    except Exception:
        return []
    talkers.sort(key=lambda t: t["mb"], reverse=True)
    return talkers[:12]


_SYSTEMD_ESC = re.compile(r"\\x([0-9a-fA-F]{2})")


def _pretty(unit):
    n = unit
    for suf in (".scope", ".service", ".slice"):
        n = n.removesuffix(suf)
    # systemd escapes '-' (and others) as \x2d in cgroup names — undo it
    n = _SYSTEMD_ESC.sub(lambda m: chr(int(m.group(1), 16)), n)
    if n.startswith("app-"):  # app-gnome-firefox-1234 -> firefox
        parts = n.split("-")
        if len(parts) >= 3:
            return parts[-2]
    return n


def load_json(path, default):
    try:
        with open(path) as f:
            return json.load(f)
    except (OSError, ValueError):
        return dict(default)


def atomic_write(path, obj):
    tmp = path + ".tmp"
    with open(tmp, "w") as f:
        json.dump(obj, f)
    os.replace(tmp, path)


def main():
    os.makedirs(RUN, exist_ok=True)
    os.makedirs(STATE, exist_ok=True)
    iface = metered_iface()
    metered, link_name = _link_state(iface)

    day = load_json(DAY_DB, {"rx": 0, "tx": 0})
    history = load_json(HISTORY_DB, {})   # per-connection day/month rollups
    ledger = load_json(LEDGER_DB, {})     # per-day per-app bytes (delta-summed)
    ts = ts_open(TS_DB)                    # hourly (connection, app) time-series
    ts_migrate_ledger(ts, ledger)         # one-time import of the JSON ledger
    prev_proc = {}                        # last proc_usage snapshot, for deltas
    proc_primed = False                   # skip the first delta (it's the baseline)
    last_attr_t = time.monotonic()        # for per-app rate (coldspot top)
    sess = {"rx": 0, "tx": 0, "since": int(time.time())}
    stance, budget = "open", None
    conf = load_conf()
    escalated = False
    auto_governed = False      # daemon is currently holding an auto-applied cold
    manual_override = False     # user set a stance by hand -> pause auto-govern
    flows = []
    advice = []
    anomalies = []
    attr_n = 0
    dns_names = {}

    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        os.unlink(SOCK)
    except OSError:
        pass
    srv.bind(SOCK)
    # 0666: the unprivileged CLI (run as the user) sets stance/budget/reset here.
    # Commands are benign local policy toggles; enforcement still goes through the
    # privileged helper, so a loose socket can't escalate.
    os.chmod(SOCK, 0o666)
    srv.listen()
    srv.settimeout(SAMPLE)

    last = read_iface(iface)
    last_t = time.monotonic()
    rate = {"rx": 0, "tx": 0}
    talk_tick = 0
    talkers = []
    src = "proc"
    while True:
        # 1) non-blocking control drain
        try:
            conn, _ = srv.accept()
            req = json.loads(conn.recv(4096).split(b"\n", 1)[0] or b"{}")
            cmd = req.get("cmd")
            if cmd == "set":
                if req.get("stance") in STANCES:
                    stance = req["stance"]
                    escalated = False  # a manual stance clears the auto latch
                    # user took the wheel: pause auto-govern until the next roam
                    manual_override = True
                    auto_governed = False
                if "budget" in req:
                    budget = req["budget"]  # MB or None
                    escalated = False
                conf = load_conf()  # pick up config edits without a restart
                conn.sendall(b'{"ok":true}\n')
            elif cmd == "reset":
                if req.get("scope") == "day":
                    day = {"rx": 0, "tx": 0}
                else:
                    sess = {"rx": 0, "tx": 0, "since": int(time.time())}
                escalated = False
                conn.sendall(b'{"ok":true}\n')
            else:
                conn.sendall(b'{"ok":true}\n')
            conn.close()
        except socket.timeout:
            pass
        except Exception:
            pass

        # 2) day rollover at local midnight
        today = time.strftime("%Y-%m-%d")
        if day.get("date") != today:
            day = {"rx": 0, "tx": 0, "date": today}
            ts_prune(ts)   # drop time-series rows past the retention window

        # 3) sample + delta (guard counter wrap / iface flap), derive live rate
        now = time.monotonic()
        cur = read_iface(iface)
        if cur and last:
            drx, dtx = cur[0] - last[0], cur[1] - last[1]
            dt = max(now - last_t, 0.001)
            if drx >= 0 and dtx >= 0:
                rate = {"rx": round(drx / dt), "tx": round(dtx / dt)}
                # per-connection history tracks every link (Brick AND home), so
                # you can see where the month went; the budget still counts only
                # the metered link.
                if link_name:
                    history_add(history, link_name, metered, today, drx, dtx)
                if metered:   # only count usage on the metered connection
                    sess["rx"] += drx
                    sess["tx"] += dtx
                    day["rx"] += drx
                    day["tx"] += dtx
        last, last_t = cur or last, now

        # 4) per-app attribution: prefer the BPF core, else systemd (every ~5th)
        talk_tick = (talk_tick + 1) % 5
        if talk_tick == 1:
            new_metered, new_link = _link_state(iface)  # Brick <-> home roam?
            if (new_metered, new_link) != (metered, link_name):
                # roamed: the BPF attribution maps still hold the previous
                # connection's bytes (kernel gates by ifindex, can't see SSID) —
                # clear them so talkers/flows track only the new connection, and
                # re-prime the ledger baseline (the cleared map jumps to ~0).
                bpf_reset_usage()
                talkers, flows = [], []
                prev_proc, proc_primed = {}, False
                manual_override = False   # new connection -> auto-govern re-decides
            metered, link_name = new_metered, new_link

            # auto-govern: cold by default on a metered link, released on an
            # unmetered one. The safety floor (critical map + DNS/DHCP/NTP) keeps
            # connectivity alive; `coldspot open` (a manual set) pauses this until
            # the next roam. Reuses the metered signal above; ~10s to react.
            if conf.get("auto_govern", True) and not manual_override:
                if metered and not auto_governed and stance != "cold":
                    if enforce("cold"):
                        stance, auto_governed = "cold", True
                elif not metered and auto_governed:
                    if enforce("open"):
                        stance, auto_governed = "open", False
            raw = read_proc_raw()
            if raw is not None:
                tk = proc_talkers(raw)                     # per-process (best)
                if proc_primed:
                    deltas = proc_deltas(prev_proc, raw)
                    ledger_add(ledger, deltas, today)
                    ts_record(ts, time.strftime("%Y-%m-%dT%H"),
                              link_name, metered, deltas)
                    attach_rates(tk, raw, prev_proc, max(now - last_attr_t, 0.001))
                talkers, src = tk, "proc"
                prev_proc, proc_primed = raw, True
                last_attr_t = now
            else:
                cg = read_bpf_usage()
                if cg is not None:
                    talkers, src = cg, "cgroup"       # per-cgroup
                else:
                    talkers, src = read_app_usage(), "systemd"
            read_dns_names(dns_names)
            flows_full = read_flows_raw(dns_names)
            if flows_full:
                enrich_unknown_flows(flows_full)  # name pre-load connections
            flows = flows_full[:20] if flows_full else []
            attr_n += 1
            if attr_n % 6 == 1:   # ~once a minute: learned per-app anomalies
                anomalies = detect_anomalies(ts, today, conf)
            advice = advise(flows_full, conf) + anomalies   # nudges + anomalies
            set_metered_cfg(iface)   # keep the core pinned to the metered link
            set_critical_cgroups()   # keep cold from throttling NM/DNS/updates
            history_prune(history)
            ledger_prune(ledger)
            atomic_write(HISTORY_DB, history)
            atomic_write(LEDGER_DB, ledger)

        # 5) budget + publish
        used_mb = (sess["rx"] + sess["tx"]) / 1e6
        pct = round(100 * used_mb / budget) if budget else None
        bstate, eta = "off", None
        if budget:
            bstate = "over" if pct >= 100 else "warn" if pct >= 80 else "ok"
            eta = budget_eta(sess["rx"] + sess["tx"], budget * 1e6,
                             int(time.time()) - sess["since"], time.time())

        # budget auto-escalation: cross the ceiling -> siege, once, if armed
        if bstate == "over" and conf["auto_siege"] and stance != "siege" \
                and not escalated:
            if enforce("siege"):
                stance, escalated = "siege", True

        atomic_write(STATUS, {
            "iface": iface, "connection": link_name, "metered": metered,
            "stance": stance, "source": src,
            "auto_siege": conf["auto_siege"], "rate_bps": rate,
            "auto_govern": conf.get("auto_govern", True), "governed": auto_governed,
            "cap_bits": conf.get("cold_cap_bits") if stance == "cold" else None,
            "flows": flows,
            "session": {"rx_mb": round(sess["rx"] / 1e6, 1),
                        "tx_mb": round(sess["tx"] / 1e6, 1),
                        "since": sess["since"]},
            "day": {"rx_mb": round(day["rx"] / 1e6, 1),
                    "tx_mb": round(day["tx"] / 1e6, 1)},
            "budget": {"limit_mb": budget, "used_mb": round(used_mb, 1),
                       "pct": pct, "state": bstate, "eta": eta},
            "talkers": talkers,
            "history": history_summary(history, today),
            "ledger": ledger_top(ledger, today),
            "advice": advice,
            "ts": int(time.time()),
        })
        atomic_write(DAY_DB, day)


if __name__ == "__main__":
    main()
