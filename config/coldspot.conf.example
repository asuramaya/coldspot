# /etc/coldspot.conf — coldspot daemon config (key = value; reloaded on any
# `coldspot stance`/`budget`/`reset`, no restart needed).

# Auto-escalate to siege the moment the session budget is exceeded. The latch
# clears when you set a stance, change the budget, or reset the meter — so you
# stay in siege until you explicitly act, then it can re-arm.
auto_siege = off

# Cold caps total egress to a smooth pipe (CAKE) and gives warmed tasks
# (coldspot uncap/run) + DNS priority WITHIN it — so claude stays responsive while
# a runaway pull/website/swarm gets only the leftover, and nothing can exceed the
# cap. Bits/second; default 2000000 (2 Mbit ~ 250 KB/s).
# cold_cap_bits = 2000000

# Fallback only (when tc/CAKE is unavailable): cold instead drops non-warmed
# egress above this BYTES/sec floor via the eBPF token bucket. Default 32768.
# cold_floor_bps = 32768

# Auto-govern: automatically enter `cold` whenever the active connection is
# metered, and release to `open` when it isn't — cold by default on the hotspot,
# no action needed. A manual stance (incl. `coldspot open`) pauses this until the
# next roam. Connectivity-critical traffic is never throttled. ON by default.
# auto_govern = on

# Auto-steer: with more than one wifi radio, keep the default route on the
# healthiest one automatically — instant failover if the primary drops, and a
# clear-margin + hysteresis rule so two near-equal radios never ping-pong. Set a
# radio manually any time with `coldspot steer <iface>`. ON by default.
# auto_steer = on

# Units the `lean` stance pauses (space-separated). Uncomment to override the
# default (packagekit snapd fwupd-refresh unattended-upgrades).
# lean_hogs = packagekit snapd fwupd-refresh unattended-upgrades

# Advisor: flag data-hungry patterns (the headline one is P2P seeding — one app
# uploading to many distinct peers). Surfaced in `coldspot status`/`advise` and
# status.json; it never changes your stance on its own. Tune or turn off:
# advise = on
# advise_tx_mb = 200      # min total upload (MB) by one app to flag
# advise_peers = 8        # min distinct peers it uploads to (fan-out)

# Learned anomaly detection: flag an app using far more today than its own daily
# baseline (from the time-series; needs a few days of history before it fires).
# Surfaced alongside advice in status / `coldspot status` / `advise`.
# anomaly = on
# anomaly_factor = 3      # flag at >= this multiple of the app's usual daily total
# anomaly_floor_mb = 200  # ignore apps under this many MB today (no noise)
